---
/**
 * contact.astro — migrated from "Contact.html".
 * Static marketing/content page. Shared chrome (head, header, nav, footer) is
 * provided by BaseLayout; this file holds the page-unique <main> body and its
 * structured data. Generated by scripts/migrate-pages.mjs, then maintained by
 * hand.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/styles-contact.css';
---
<BaseLayout
  title="Contact Tavali — Book a Demo or Get in Touch"
  description="Contact Tavali to book a personalized demo of the AI-native dental operating system, or reach out with a general question, partnership, or press inquiry. Tell us about your practice and we'll be in touch."
  canonical="https://www.tavali.com/company/contact/"
  ogDescription="The best way to see Tavali is a personalized demo built around your practice — and we're happy to answer any question along the way."
  ogImage="https://www.tavali.com/og-contact.png"
  ogImageAlt="Contact Tavali — book a demo of the AI-native dental operating system."
  thumbnailLabel="Contact"
>
  <Fragment slot="jsonld" set:html={`<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": "https://www.tavali.com/company/contact/#contactpage",
  "url": "https://www.tavali.com/company/contact/",
  "name": "Contact Tavali",
  "description": "Book a personalized demo of Tavali or get in touch with general, partnership, or press inquiries.",
  "isPartOf": { "@id": "https://www.tavali.com/#website" },
  "about": { "@id": "https://www.tavali.com/#organization" }
}
</script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://www.tavali.com/#organization",
  "name": "Tavali, Inc.",
  "url": "https://www.tavali.com/",
  "logo": {
    "@type": "ImageObject",
    "url": "https://www.tavali.com/logo.png",
    "width": 2015,
    "height": 720
  },
  "description": "Tavali is the AI-native operating system for dental practices, unifying clinical care, operations, and revenue in one platform.",
  "contactPoint": [
    {
      "@type": "ContactPoint",
      "contactType": "Sales",
      "name": "Demo & Sales",
      "email": "hello@tavali.com",
      "areaServed": "US",
      "availableLanguage": "English"
    },
    {
      "@type": "ContactPoint",
      "contactType": "Customer Support",
      "name": "General Inquiries",
      "email": "hello@tavali.com",
      "areaServed": "US",
      "availableLanguage": "English"
    },
    {
      "@type": "ContactPoint",
      "contactType": "Partnerships",
      "email": "partnerships@tavali.com",
      "areaServed": "US",
      "availableLanguage": "English"
    },
    {
      "@type": "ContactPoint",
      "contactType": "Press",
      "email": "press@tavali.com",
      "areaServed": "US",
      "availableLanguage": "English"
    }
  ],
  "sameAs": [
    "https://www.linkedin.com/company/tavali",
    "https://x.com/tavali"
  ]
}
</script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": "https://www.tavali.com/company/contact/#breadcrumb",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.tavali.com/" },
    { "@type": "ListItem", "position": 2, "name": "Company", "item": "https://www.tavali.com/company/" },
    { "@type": "ListItem", "position": 3, "name": "Contact", "item": "https://www.tavali.com/company/contact/" }
  ]
}
</script>`} />

<main id="main">

  <!-- ===================================================== HERO ===================================================== -->
  <section class="hero hero--contact" aria-labelledby="page-h">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-bg-dots"></div>
      <canvas class="hero-canvas"></canvas>
      <div class="hero-glow"></div>
    </div>
    <div class="container">
      <!-- <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li class="sep" aria-hidden="true">/</li>
          <li><span class="crumb-static">Company</span></li>
          <li class="sep" aria-hidden="true">/</li>
          <li><span aria-current="page">Contact</span></li>
        </ol>
      </nav> -->
      <div class="hero-grid">
        <div class="hero-copy">
          <span class="eyebrow" data-reveal>Contact</span>
          <h1 id="page-h" data-reveal data-delay="1">Contact Tavali</h1>
          <p class="hero-def" data-reveal data-delay="1">The best way to see Tavali is a personalized demo built around your practice — and we&rsquo;re happy to answer any question <span class="accent">along the way</span>.</p>
          <p class="hero-sub" data-reveal data-delay="2">Tell us a little about your practice and what you&rsquo;re looking to solve, and we&rsquo;ll be in touch.</p>
          <div class="hero-cta" data-reveal data-delay="3">
            <a class="btn btn--primary btn--hero" href="#contact-form">Book a Demo <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a class="btn btn--ghost btn--lg" href="#other-ways">Other ways to reach us</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== PRIMARY ACTION + FORM ===================================================== -->
  <section class="section" id="contact" aria-labelledby="primary-h">
    <div class="container">
      <div class="contact-grid">

        <!-- LEFT: primary action panel + form -->
        <div class="contact-main">
          <div class="primary-panel" data-reveal>
            <span class="pp-flag"><span class="pip" aria-hidden="true"></span> Primary — start here</span>
            <h2 id="primary-h">Book a demo</h2>
            <p>See how Tavali brings clinical care, operations, and revenue into one AI-native platform — tailored to how your practice actually works, whether you&rsquo;re a single office or a multi-location DSO.</p>
          </div>

          <div class="form-card" id="contact-form" data-reveal data-delay="1">
            <!-- ================================================================
                 FORM ENDPOINT — connect to a real handler here.
                 Replace `action` with your form service (e.g. Formspree,
                 HubSpot, a serverless function, or your CRM intake endpoint)
                 and set `method="post"`. The JS below intercepts submit,
                 validates, and shows the inline success state; remove/adjust
                 the e.preventDefault() once a real endpoint is wired so the
                 POST actually fires (or submit via fetch() to the endpoint).
                 ================================================================ -->
            <h3>Tell us about your practice</h3>
            <p class="form-intro">Fields marked <span style="color:var(--accent-ink);font-weight:700;">*</span> are required. The more you share, the more tailored your demo.</p>

            <form class="lead-form" id="lead-form" action="#REPLACE_WITH_FORM_ENDPOINT" method="post" novalidate aria-describedby="form-note">
              <div class="field-grid">
                <div class="field">
                  <label for="f-name">Full name <span class="req" aria-hidden="true">*</span></label>
                  <input type="text" id="f-name" name="name" autocomplete="name" required aria-required="true" aria-describedby="err-name" placeholder="Dr. Jane Smith" />
                  <span class="field-error" id="err-name" role="alert">Please enter your name.</span>
                </div>
                <div class="field">
                  <label for="f-email">Work email <span class="req" aria-hidden="true">*</span></label>
                  <input type="email" id="f-email" name="email" autocomplete="email" required aria-required="true" aria-describedby="err-email" placeholder="jane@yourpractice.com" />
                  <span class="field-error" id="err-email" role="alert">Please enter a valid email address.</span>
                </div>
                <div class="field">
                  <label for="f-org">Practice / organization name <span class="req" aria-hidden="true">*</span></label>
                  <input type="text" id="f-org" name="organization" autocomplete="organization" required aria-required="true" aria-describedby="err-org" placeholder="Smith Family Dental" />
                  <span class="field-error" id="err-org" role="alert">Please enter your practice or organization name.</span>
                </div>
                <div class="field">
                  <label for="f-type">Organization type <span class="req" aria-hidden="true">*</span></label>
                  <select id="f-type" name="org_type" required aria-required="true" aria-describedby="err-type">
                    <option value="" disabled selected>Select one…</option>
                    <option value="single-office">Single Office</option>
                    <option value="group-practice">Group Practice</option>
                    <option value="dso">DSO</option>
                    <option value="franchise">Franchise</option>
                    <option value="other">Other</option>
                  </select>
                  <span class="field-error" id="err-type" role="alert">Please select an organization type.</span>
                </div>
                <div class="field">
                  <label for="f-locations">Number of locations <span class="opt">(optional)</span></label>
                  <input type="number" id="f-locations" name="locations" min="1" inputmode="numeric" placeholder="e.g. 3" />
                </div>
                <div class="field">
                  <label for="f-phone">Phone <span class="opt">(optional)</span></label>
                  <input type="tel" id="f-phone" name="phone" autocomplete="tel" inputmode="tel" maxlength="14" placeholder="(098) 765-4567" />
                </div>
                <div class="field col-span-2">
                  <label for="f-help">What can we help with? <span class="req" aria-hidden="true">*</span></label>
                  <select id="f-help" name="help_with" required aria-required="true" aria-describedby="err-help">
                    <option value="demo" selected>Book a demo</option>
                    <option value="general">General question</option>
                    <option value="partnership">Partnership</option>
                    <option value="press">Press</option>
                    <option value="careers">Careers</option>
                  </select>
                  <span class="field-error" id="err-help" role="alert">Please choose what we can help with.</span>
                </div>
                <div class="field col-span-2">
                  <label for="f-message">Message <span class="req" aria-hidden="true">*</span></label>
                  <textarea id="f-message" name="message" required aria-required="true" aria-describedby="err-message" placeholder="Tell us about your practice and what you're hoping to solve — documentation, claims, scheduling, staffing, revenue…"></textarea>
                  <span class="field-error" id="err-message" role="alert">Please add a short message.</span>
                </div>
              </div>

              <div class="form-foot">
                <button type="submit" class="btn btn--primary btn--lg">Request a Demo <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
                <p class="form-note" id="form-note">We&rsquo;ll only use your details to respond to your request. No spam, ever.</p>
              </div>
            </form>

            <!-- Inline success state (revealed by JS; focus moved here on submit) -->
            <div class="form-success" id="form-success" role="status" aria-live="polite" tabindex="-1">
              <span class="fs-mark" aria-hidden="true">
                <svg width="30" height="30" viewBox="0 0 24 24"><path d="M4 12.5l5 5L20 6.5" fill="none" stroke="#3F73AA" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <h3>Thanks — request received.</h3>
              <p>We&rsquo;ve received your request and we&rsquo;ll be in touch shortly to schedule a demo tailored to your practice.</p>
            </div>
          </div>
        </div>

        <!-- RIGHT: other ways to reach us -->
        <aside class="contact-aside" id="other-ways" aria-labelledby="other-h">
          <p class="aside-label" id="other-h">Other ways to reach us</p>

          <a class="reach-card" href="mailto:hello@tavali.com" data-reveal>
            <span class="rc-ico" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2.5" fill="none" stroke="#3F73AA" stroke-width="1.6"/><path d="M4 7l8 6 8-6" fill="none" stroke="#3F73AA" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            <span>
              <span class="rc-t">General inquiries</span>
              <span class="rc-link">hello@tavali.com</span>
              <span class="rc-ph">Placeholder — confirm or replace.</span>
            </span>
          </a>

          <a class="reach-card" href="mailto:partnerships@tavali.com" data-reveal data-delay="1">
            <span class="rc-ico" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24"><path d="M8 12a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM16 18a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" fill="none" stroke="#3F73AA" stroke-width="1.6"/><path d="M10.5 10.5l3 3" stroke="#3F73AA" stroke-width="1.6" stroke-linecap="round"/></svg></span>
            <span>
              <span class="rc-t">Partnerships</span>
              <span class="rc-link">partnerships@tavali.com</span>
              <span class="rc-ph">Placeholder — confirm or replace.</span>
            </span>
          </a>

          <a class="reach-card" href="mailto:press@tavali.com" data-reveal data-delay="2">
            <span class="rc-ico" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24"><path d="M4 6h12v12H6a2 2 0 0 1-2-2V6z" fill="none" stroke="#3F73AA" stroke-width="1.6" stroke-linejoin="round"/><path d="M16 9h3v7a2 2 0 0 1-2 2M7 9h6M7 12h6M7 15h4" fill="none" stroke="#3F73AA" stroke-width="1.6" stroke-linecap="round"/></svg></span>
            <span>
              <span class="rc-t">Press &amp; media</span>
              <span class="rc-link">press@tavali.com</span>
              <span class="rc-ph">Placeholder — confirm or replace.</span>
            </span>
          </a>

          <a class="reach-card" href="/team" data-reveal data-delay="2">
            <span class="rc-ico" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24"><circle cx="9" cy="8" r="3" fill="none" stroke="#3F73AA" stroke-width="1.6"/><path d="M3.5 19c0-3 2.5-5 5.5-5s5.5 2 5.5 5M16 6.5a3 3 0 0 1 0 5.5M20.5 19c0-2.2-1.2-3.8-3-4.5" fill="none" stroke="#3F73AA" stroke-width="1.6" stroke-linecap="round"/></svg></span>
            <span>
              <span class="rc-t">Careers</span>
              <span class="rc-link">We&rsquo;re growing — see the team <svg class="btn-arrow" width="14" height="14" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            </span>
          </a>
        </aside>

      </div>
    </div>
  </section>

  <!-- ===================================================== REASSURANCE ===================================================== -->
  <section class="section bg-surface" id="reassure" aria-labelledby="reassure-h">
    <div class="container">
      <div class="reassure-grid">
        <div>
          <span class="eyebrow" data-reveal>What happens next</span>
          <h2 id="reassure-h" class="reassure-lead" data-reveal data-delay="1">Every demo is built around <span class="accent">your practice</span> — never a generic walkthrough.</h2>
        </div>
        <div class="reassure-body" data-reveal data-delay="1">
          <p>We&rsquo;ll review your request and reach out to schedule a demo tailored to your practice. Demos are personalized — not a generic walkthrough — so we&rsquo;ll ask a little about how you operate today.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== FAQ SHORTCUT ===================================================== -->
  <section class="section section--tight" id="faq-shortcut" aria-labelledby="faqs-h">
    <div class="container">
      <div class="faq-shortcut" data-reveal>
        <div class="fs-copy">
          <span class="fs-ico" aria-hidden="true"><svg width="22" height="22" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" fill="none" stroke="#3F73AA" stroke-width="1.6"/><path d="M9.4 9.2a2.6 2.6 0 0 1 5 .9c0 1.7-2.4 2-2.4 3.4" fill="none" stroke="#3F73AA" stroke-width="1.6" stroke-linecap="round"/><circle cx="12" cy="17" r="1.1" fill="#3F73AA"/></svg></span>
          <p id="faqs-h">Looking for quick answers? Visit our FAQ.</p>
        </div>
        <a class="btn btn--ghost" href="/faq">Go to FAQ <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
      </div>
    </div>
  </section>

  <!-- ===================================================== FINAL CTA ===================================================== -->
  <section class="section bg-navy final-cta" id="final-cta" aria-labelledby="final-h">
    <div class="hero-glow" aria-hidden="true" style="left:50%;top:-30%;transform:translateX(-50%);"></div>
    <div class="dot-field" aria-hidden="true" style="opacity:.1;-webkit-mask-image:radial-gradient(ellipse 70% 100% at 50% 0,#000,transparent 70%);mask-image:radial-gradient(ellipse 70% 100% at 50% 0,#000,transparent 70%);"></div>
    <div class="container final-cta-inner">
      <h2 id="final-h" data-reveal>Ready to see Tavali in action?</h2>
      <p class="lead" data-reveal data-delay="1">Book a 30-minute demo and we&rsquo;ll walk your team through Tavali on your workflows.</p>
      <div class="final-cta-row" data-reveal data-delay="2">
        <a class="btn btn--primary btn--lg" href="#contact-form">Book a Demo <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        <a class="btn btn--ghost btn--lg" href="/platform">Explore the Platform</a>
      </div>
    </div>
  </section>

</main>

  <script>
    import '../scripts/contact-form.js';
  </script>
</BaseLayout>
