---
/**
 * team.astro — migrated from "Team.html".
 * Static marketing/content page. Shared chrome (head, header, nav, footer) is
 * provided by BaseLayout; this file holds the page-unique <main> body and its
 * structured data. Generated by scripts/migrate-pages.mjs, then maintained by
 * hand.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/styles-team.css';
---
<BaseLayout
  title="Team — The People Building Tavali"
  description="Meet the people building Tavali — two complementary co-founders combining deep dental-clinical expertise with a proven track record of building and scaling AI and software companies."
  canonical="https://www.tavali.com/company/team/"
  ogDescription="Two complementary co-founders — one who has lived the problems Tavali solves, and one who has repeatedly built the kind of platform that solves them."
  ogImage="https://www.tavali.com/og-team.png"
  ogImageAlt="The team building Tavali, the AI-native operating system for dental practices."
  thumbnailLabel="Team"
>
  <Fragment slot="jsonld" set:html={`<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://www.tavali.com/#organization",
  "name": "Tavali, Inc.",
  "url": "https://www.tavali.com/",
  "logo": {
    "@type": "ImageObject",
    "url": "https://www.tavali.com/logo.png",
    "width": 2015,
    "height": 720
  },
  "slogan": "The AI-native operating system for dental practices.",
  "description": "Tavali is an AI-native operating system for dental practices that unifies clinical care, operations, and revenue into a single platform.",
  "foundingDate": "2025",
  "founders": [
    {
      "@type": "Person",
      "name": "Mehrak Assadian",
      "jobTitle": "Co-Founder & CEO",
      "description": "A doctor, healthcare provider, and dental-practice owner with more than 15 years of experience running a dental practice, with an MBA from the University of Michigan's Ross School of Business. She advises dental practices on strategy and operations and is an AI startup founder.",
      "alumniOf": "University of Michigan Ross School of Business",
      "sameAs": ["https://www.linkedin.com/in/tavali-mehrak-assadian"]
    },
    {
      "@type": "Person",
      "name": "Anil Jwalanna",
      "jobTitle": "Co-Founder & CTO",
      "description": "A 5x founder and technology executive with 15+ years building and scaling B2B SaaS and AI/ML platforms as both an early-stage CTO and a senior technology leader inside large enterprises.",
      "alumniOf": ["Columbia Business School", "UC Berkeley Haas School of Business"],
      "sameAs": ["https://www.linkedin.com/in/tavali-anil-jwalanna"]
    }
  ],
  "employee": [
    {
      "@type": "Person",
      "name": "Mehrak Assadian",
      "jobTitle": "Co-Founder & CEO"
    },
    {
      "@type": "Person",
      "name": "Anil Jwalanna",
      "jobTitle": "Co-Founder & CTO"
    }
  ]
}
</script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": "https://www.tavali.com/company/team/#breadcrumb",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.tavali.com/" },
    { "@type": "ListItem", "position": 2, "name": "Company", "item": "https://www.tavali.com/company/" },
    { "@type": "ListItem", "position": 3, "name": "Team", "item": "https://www.tavali.com/company/team/" }
  ]
}
</script>`} />

<main id="main">

  <!-- ===================================================== HERO ===================================================== -->
  <section class="hero hero--team" aria-labelledby="page-h">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-bg-dots"></div>
      <canvas class="hero-canvas"></canvas>
      <div class="hero-glow"></div>
    </div>
    <div class="container">
      <div class="hero-grid">
        <div class="hero-copy">
          <span class="eyebrow" data-reveal>Our team</span>
          <h1 id="page-h" data-reveal data-delay="1">Our Team</h1>
          <p class="hero-def" data-reveal data-delay="1">Tavali is built by a team that combines deep dental-clinical expertise with a proven track record of building and scaling <span class="accent">technology companies</span>.</p>
          <p class="hero-sub" data-reveal data-delay="2">Two complementary co-founders — one who has lived the problems Tavali solves, and one who has repeatedly built the kind of platform that solves them.</p>
          <div class="hero-cta" data-reveal data-delay="3">
            <a class="btn btn--primary btn--hero" href="#team-cta">Book a Demo <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a class="btn btn--ghost btn--lg" href="/about">About Tavali</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== FOUNDERS ===================================================== -->
  <section class="section" id="founders" aria-labelledby="founders-h">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow" data-reveal>Founders</span>
        <h2 id="founders-h" data-reveal data-delay="1">The people building Tavali.</h2>
        <p class="lead" data-reveal data-delay="2">A deliberately complementary pairing — clinical depth on one side, repeat-founder execution on the other.</p>
      </div>

      <div class="founders">
        <!-- Founder 1 -->
        <article class="founder" aria-labelledby="founder-ma">
          <div class="founder-photo-wrap" data-reveal>
            <div class="founder-photo" role="img" aria-label="Mehrak Assadian, Co-Founder and CEO of Tavali">
              <div class="dot-field" aria-hidden="true"></div>
              <div class="fp-inner" aria-hidden="true">
                <span class="fp-mono">MA</span>
                <span class="fp-label">
                  <svg width="13" height="13" viewBox="0 0 16 16" aria-hidden="true"><circle cx="8" cy="5.5" r="3" fill="none" stroke="currentColor" stroke-width="1.4"/><path d="M2.5 14c0-3 2.6-5 5.5-5s5.5 2 5.5 5" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                  Headshot
                </span>
              </div>
            </div>
          </div>
          <div class="founder-body" data-reveal data-delay="1">
            <h3 class="founder-name" id="founder-ma">Mehrak Assadian</h3>
            <p class="founder-role"><span class="pip" aria-hidden="true"></span> Co-Founder &amp; CEO</p>
            <p class="founder-bio">Mehrak is a doctor, healthcare provider, and dental-practice owner with more than 15 years of experience running a dental practice, and she holds an MBA from the University of Michigan&rsquo;s Ross School of Business. In addition to operating her own practice, she works as a strategy and business consultant to dental practices and is an AI startup founder.</p>
            <p class="founder-bio">She brings deep frontline experience across integrated healthcare systems, dental operations, workflow optimization, revenue-cycle challenges, and patient-care delivery. Through her direct work with dental practices, she has identified the major inefficiencies Tavali is built to solve — in documentation, insurance verification, billing, staffing, patient communication, and revenue leakage.</p>
            <p class="founder-bio">Her background uniquely bridges clinical care, business development, operations, and AI innovation, giving Tavali a leader who understands both the provider experience and the business realities of the modern dental practice.</p>
            <div class="founder-tags" aria-hidden="true">
              <span class="ftag">15+ yrs practice owner</span>
              <span class="ftag">Dental strategy consultant</span>
              <span class="ftag">MBA, Michigan Ross</span>
            </div>
          </div>
        </article>

        <!-- Founder 2 -->
        <article class="founder" aria-labelledby="founder-aj">
          <div class="founder-photo-wrap" data-reveal>
            <div class="founder-photo" role="img" aria-label="Anil Jwalanna, Co-Founder and CTO of Tavali">
              <div class="dot-field" aria-hidden="true"></div>
              <div class="fp-inner" aria-hidden="true">
                <span class="fp-mono">AJ</span>
                <span class="fp-label">
                  <svg width="13" height="13" viewBox="0 0 16 16" aria-hidden="true"><circle cx="8" cy="5.5" r="3" fill="none" stroke="currentColor" stroke-width="1.4"/><path d="M2.5 14c0-3 2.6-5 5.5-5s5.5 2 5.5 5" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                  Headshot
                </span>
              </div>
            </div>
          </div>
          <div class="founder-body" data-reveal data-delay="1">
            <h3 class="founder-name" id="founder-aj">Anil Jwalanna</h3>
            <p class="founder-role"><span class="pip" aria-hidden="true"></span> Co-Founder &amp; CTO</p>
            <p class="founder-bio">Anil is a 5x founder and technology executive with 15+ years building and scaling B2B SaaS and AI/ML platforms, as both a hands-on early-stage CTO and a senior technology leader inside large enterprises.</p>
            <p class="founder-bio">He was CTO of Zuma, an AI/ML and generative-AI platform that joined Y Combinator and raised from Andreessen Horowitz, reaching $1M+ in annual contract value within 12 months; founder and CEO of WittyParrot, a B2B SaaS knowledge-automation company where he raised $4M and built a 50+ person engineering organization across the US and India; and founder and CEO of PushPoint Mobile, which he led from idea to acquisition by Capital One after winning Wells Fargo and VeriFone as customers. Earlier, as CTO of iCharts, he built a cloud analytics platform serving millions of users globally.</p>
            <p class="founder-bio">His expertise spans generative AI and machine learning, SaaS and microservices architecture, cloud-native infrastructure (AWS, Azure, GCP), and large-scale data engineering. As Tavali&rsquo;s CTO, he leads the company&rsquo;s technical vision, system design, and product-development strategy. He holds a BS in Engineering and Executive MBAs from Columbia Business School and UC Berkeley&rsquo;s Haas School of Business.</p>
            <div class="founder-tags" aria-hidden="true">
              <span class="ftag">5x founder</span>
              <span class="ftag">Ex-CTO, Zuma (YC)</span>
              <span class="ftag">Exit to Capital One</span>
              <span class="ftag">Columbia &amp; Berkeley Haas</span>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ===================================================== WHY THIS TEAM ===================================================== -->
  <section class="section bg-navy" id="why-team" aria-labelledby="why-team-h">
    <div class="dot-field" aria-hidden="true" style="opacity:.1;"></div>
    <div class="container">
      <div class="why-grid">
        <div class="why-head">
          <span class="eyebrow" data-reveal>Why this team</span>
          <h2 id="why-team-h" class="why-team-lead" data-reveal data-delay="1">A pairing built to cover <span class="accent">both sides</span> of the problem.</h2>
        </div>
        <div class="why-body">
          <p data-reveal>Mehrak and Anil are a deliberately complementary pairing that covers both sides of what it takes to build an AI-native platform for dentistry. Mehrak brings the clinical credibility, dental-operations depth, and customer empathy that come only from owning and running a practice for 15+ years and advising others — she lives the problems Tavali solves and can open doors with practices, payers, and DSOs.</p>
          <p data-reveal data-delay="1">Anil brings 15+ years of repeat-founder execution and technical leadership, with ventures that have gone through Y Combinator and accelerator programs, raised from top-tier investors, scaled to millions of users, and exited to a major financial institution. One co-founder owns the dental domain and the demand side; the other has repeatedly turned technical vision into shipped, funded, and scaled products.</p>
          <p data-reveal data-delay="2">Their combined networks across dentistry, healthcare, enterprise technology, and the startup and investment communities give Tavali an unusually strong reach for early customer access, hiring, and partnerships.</p>

          <div class="why-split" data-reveal data-delay="2" aria-hidden="true">
            <div class="why-pillar">
              <span class="wp-ico" data-dots="0010001110111110111000100" data-size="26"></span>
              <h3>The dental domain</h3>
              <p>Clinical credibility, operations depth, and the demand side — practices, payers, and DSOs.</p>
            </div>
            <span class="why-plus">+</span>
            <div class="why-pillar">
              <span class="wp-ico" data-dots="1000101110112110111010001" data-size="26"></span>
              <h3>Proven execution</h3>
              <p>Repeat-founder technical leadership — shipped, funded, scaled, and exited products.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== GROWING / ADVISORS ===================================================== -->
  <section class="section bg-surface" id="growing" aria-labelledby="growing-h">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow" data-reveal>We&rsquo;re growing</span>
        <h2 id="growing-h" data-reveal data-delay="1">Building the team that will modernize dental care.</h2>
        <p class="lead" data-reveal data-delay="2">Tavali is assembling a team of clinical, engineering, and operating talent to modernize dental care. These seats are filling now.</p>
      </div>
      <div class="grow-grid">
        <article class="grow-card" data-reveal>
          <span class="grow-avatar"><span class="dot-field" aria-hidden="true"></span><svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 7v10M7 12h10" stroke="#4A7DB5" stroke-width="2" stroke-linecap="round"/></svg></span>
          <p class="gc-role">Founding Engineers</p>
          <p class="gc-note">Building the AI-native platform at the core of every dental practice.</p>
          <span class="gc-soon">Joining soon</span>
        </article>
        <article class="grow-card" data-reveal data-delay="1">
          <span class="grow-avatar"><span class="dot-field" aria-hidden="true"></span><svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 7v10M7 12h10" stroke="#4A7DB5" stroke-width="2" stroke-linecap="round"/></svg></span>
          <p class="gc-role">Clinical Advisors</p>
          <p class="gc-note">Dentists and hygienists keeping the product grounded in real chairside practice.</p>
          <span class="gc-soon">Joining soon</span>
        </article>
        <article class="grow-card" data-reveal data-delay="2">
          <span class="grow-avatar"><span class="dot-field" aria-hidden="true"></span><svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 7v10M7 12h10" stroke="#4A7DB5" stroke-width="2" stroke-linecap="round"/></svg></span>
          <p class="gc-role">Operations &amp; RCM</p>
          <p class="gc-note">Experts in billing, revenue cycle, and the business of running practices.</p>
          <span class="gc-soon">Joining soon</span>
        </article>
      </div>
    </div>
  </section>

  <!-- ===================================================== JOIN US ===================================================== -->
  <section class="section" id="join" aria-labelledby="join-h">
    <div class="container">
      <div class="join-band" data-reveal>
        <div>
          <h2 id="join-h">Help us build the future of dental care.</h2>
          <p>We&rsquo;re looking for people who care about clinicians, patients, and building software that does real work.</p>
        </div>
        <div class="join-actions">
          <a class="btn btn--primary btn--lg" href="#team-cta">Get in touch <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== FINAL CTA ===================================================== -->
  <section class="section bg-navy final-cta" id="team-cta" aria-labelledby="final-h">
    <div class="hero-glow" aria-hidden="true" style="left:50%;top:-30%;transform:translateX(-50%);"></div>
    <div class="dot-field" aria-hidden="true" style="opacity:.1;-webkit-mask-image:radial-gradient(ellipse 70% 100% at 50% 0,#000,transparent 70%);mask-image:radial-gradient(ellipse 70% 100% at 50% 0,#000,transparent 70%);"></div>
    <div class="container final-cta-inner">
      <h2 id="final-h" data-reveal>Want to meet the team behind Tavali?</h2>
      <p class="lead" data-reveal data-delay="1">Book a 30-minute demo and we&rsquo;ll walk your team through Tavali on your workflows.</p>
      <div class="final-cta-row" data-reveal data-delay="2">
        <a class="btn btn--primary btn--lg" href="#">Book a Demo <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        <a class="btn btn--ghost btn--lg" href="/about">About Tavali</a>
      </div>
    </div>
  </section>

</main>
</BaseLayout>
