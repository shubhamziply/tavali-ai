---
/**
 * security.astro — migrated from "Security.html".
 * Static marketing/content page. Shared chrome (head, header, nav, footer) is
 * provided by BaseLayout; this file holds the page-unique <main> body and its
 * structured data. Generated by scripts/migrate-pages.mjs, then maintained by
 * hand.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/styles-security.css';
---
<BaseLayout
  title="Tavali Security &amp; Compliance — Protecting Dental Patient Data"
  description="Tavali is built to protect patient data with privacy-by-design, encryption, strict access controls, and audit logging. Learn our approach to data protection, HIPAA-aligned operations, AI governance, and our commitment to industry-standard security as we scale."
  canonical="https://www.tavali.com/resources/security/"
  ogDescription="Security isn't a feature we added — it's part of how the platform is designed. Our approach to protecting patient data and supporting HIPAA-aligned operations."
  ogImage="https://www.tavali.com/og-security.png"
  ogImageAlt="Tavali Security & Compliance — protecting dental patient data."
  thumbnailLabel="Security"
>
  <Fragment slot="jsonld" set:html={`<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": "https://www.tavali.com/resources/security/#faq",
  "url": "https://www.tavali.com/resources/security/",
  "inLanguage": "en-US",
  "mainEntity": [
    { "@type": "Question", "name": "Is Tavali secure?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali is built with privacy-by-design, encryption, access controls, and audit logging to protect patient data." } },
    { "@type": "Question", "name": "Does Tavali support HIPAA-aligned operations?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Tavali is designed to support HIPAA-aligned workflows with administrative, technical, and physical safeguards appropriate to protected health information." } },
    { "@type": "Question", "name": "How does Tavali protect data across multiple locations?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali is built to isolate each organization’s data and enforce role-based access, including across multi-location deployments." } },
    { "@type": "Question", "name": "Can Tavali’s AI take clinical action without approval?", "acceptedAnswer": { "@type": "Answer", "text": "No. Clinical actions are held for provider approval through a non-overridable safeguard; only routine, low-risk tasks can run autonomously." } },
    { "@type": "Question", "name": "Who can access patient data in Tavali?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali is designed to enforce role-based access controls so users can access only the data they are authorized to see." } }
  ]
}
</script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": "https://www.tavali.com/resources/security/#breadcrumb",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.tavali.com/" },
    { "@type": "ListItem", "position": 2, "name": "Resources", "item": "https://www.tavali.com/resources/" },
    { "@type": "ListItem", "position": 3, "name": "Security & Compliance", "item": "https://www.tavali.com/resources/security/" }
  ]
}
</script>`} />

<main id="main">

  <!-- ===================================================== HERO ===================================================== -->
  <section class="hero hero--security" aria-labelledby="page-h">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-bg-dots"></div>
      <div class="hero-glow"></div>
    </div>
    <div class="container">
      <div class="hero-grid">
        <div class="hero-copy">
          <span class="eyebrow" data-reveal>Security &amp; Compliance</span>
          <h1 id="page-h" data-reveal data-delay="1">Security &amp; Compliance</h1>
          <p class="hero-def" data-reveal data-delay="1">Tavali is built to protect patient data with <span class="accent">privacy-by-design</span>, encryption, strict access controls, and audit logging across every practice and location.</p>
          <p class="hero-sub" data-reveal data-delay="2">Security isn&rsquo;t a feature we added — it&rsquo;s part of how the platform is designed. Here&rsquo;s our approach to protecting your patients&rsquo; data and supporting HIPAA-aligned operations.</p>
          <div class="hero-cta" data-reveal data-delay="3">
            <a class="btn btn--primary btn--hero" href="#security-cta">Book a Demo <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a class="btn btn--ghost btn--lg" href="/faq">Read the FAQ</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== PRINCIPLES ===================================================== -->
  <section class="section" id="principles" aria-labelledby="principles-h">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Our security approach</span>
        <h2 id="principles-h">Security built into the platform, not bolted on.</h2>
        <p class="lead">Tavali&rsquo;s security model rests on a set of principles applied consistently across the platform — from how data is stored to how AI is allowed to act.</p>
      </div>
      <div class="sec-grid">
        <article class="sec-card" data-reveal>
          <span class="sec-ico" data-dots="0010001110111110111000100" data-size="52"></span>
          <h3>Privacy by design</h3>
          <p>Tavali is designed so that protecting patient data is built into the platform&rsquo;s architecture, not bolted on afterward.</p>
        </article>
        <article class="sec-card" data-reveal>
          <span class="sec-ico" data-dots="1111110001100011000111111" data-size="52"></span>
          <h3>Encryption</h3>
          <p>Tavali is built to encrypt sensitive data in transit and at rest.</p>
        </article>
        <article class="sec-card" data-reveal>
          <span class="sec-ico" data-dots="0100010101001000101000100" data-size="52"></span>
          <h3>Access controls</h3>
          <p>Tavali is designed to enforce role-based access so people see only the data they&rsquo;re authorized to see.</p>
        </article>
        <article class="sec-card" data-reveal>
          <span class="sec-ico" data-dots="1111010101110101010101111" data-size="52"></span>
          <h3>Audit logging</h3>
          <p>Tavali is designed to maintain audit trails of access and key actions across the platform.</p>
        </article>
        <article class="sec-card" data-reveal>
          <span class="sec-ico" data-dots="1100111001001001110011001" data-size="52"></span>
          <h3>Tenant isolation</h3>
          <p>Tavali is built to keep each organization&rsquo;s data isolated, including across multi-location deployments.</p>
        </article>
        <article class="sec-card" data-reveal>
          <span class="sec-ico" data-dots="0010001110101010111000100" data-size="52"></span>
          <h3>AI within limits</h3>
          <p>Tavali&rsquo;s AI agents operate under a governance model with a non-overridable safeguard that keeps clinical decisions with the provider.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ===================================================== DATA PROTECTION ===================================================== -->
  <section class="section bg-surface" id="data-protection" aria-labelledby="data-h">
    <div class="container">
      <div class="sec-band-grid">
        <div class="sec-band-copy" data-reveal>
          <span class="eyebrow">Data protection</span>
          <h2 id="data-h">How Tavali protects patient data.</h2>
          <p class="lead">Tavali is designed to safeguard protected health information through layered controls — encryption in transit and at rest, role-based access, audit logging, and isolation between organizations and locations — so that sensitive data stays protected throughout the platform.</p>
        </div>
        <div class="sec-band-visual" data-reveal data-delay="1">
          <div class="sec-visual">
            <div class="sec-layer"><span class="sec-layer-ico" data-dots="1111110001100011000111111" data-size="38"></span><span><span class="sec-layer-t">Encryption in transit &amp; at rest</span><span class="sec-layer-d" style="display:block;">Sensitive data is protected end to end</span></span></div>
            <div class="sec-layer"><span class="sec-layer-ico" data-dots="0100010101001000101000100" data-size="38"></span><span><span class="sec-layer-t">Role-based access</span><span class="sec-layer-d" style="display:block;">People see only what they&rsquo;re authorized to</span></span></div>
            <div class="sec-layer"><span class="sec-layer-ico" data-dots="1111010101110101010101111" data-size="38"></span><span><span class="sec-layer-t">Audit logging</span><span class="sec-layer-d" style="display:block;">Trails of access and key actions</span></span></div>
            <div class="sec-layer"><span class="sec-layer-ico" data-dots="1100111001001001110011001" data-size="38"></span><span><span class="sec-layer-t">Tenant isolation</span><span class="sec-layer-d" style="display:block;">Each organization&rsquo;s data kept separate</span></span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== HIPAA ===================================================== -->
  <section class="section" id="hipaa" aria-labelledby="hipaa-h">
    <div class="container">
      <div class="sec-band-grid flip">
        <div class="sec-band-copy" data-reveal>
          <span class="eyebrow">Regulatory alignment</span>
          <h2 id="hipaa-h">Designed to support HIPAA-aligned operations.</h2>
          <p class="lead">Tavali is designed to support HIPAA-aligned workflows, with administrative, technical, and physical safeguards appropriate to handling protected health information, and to use AI in an assistive, provider-confirmed manner consistent with responsible clinical use.</p>
          <p class="sec-clarify"><strong>A note on language:</strong> HIPAA is a compliance obligation, not a certification. We therefore describe Tavali as <em>designed to support</em> HIPAA-aligned operations, rather than claiming a certification that does not exist.</p>
        </div>
        <div class="sec-band-visual" data-reveal data-delay="1">
          <div class="sec-visual">
            <div class="sec-layer"><span class="sec-layer-ico" data-dots="1111010001102011000101111" data-size="38"></span><span><span class="sec-layer-t">Administrative safeguards</span><span class="sec-layer-d" style="display:block;">Policies and access governance</span></span></div>
            <div class="sec-layer"><span class="sec-layer-ico" data-dots="0010001110111110111000100" data-size="38"></span><span><span class="sec-layer-t">Technical safeguards</span><span class="sec-layer-d" style="display:block;">Encryption, access control, logging</span></span></div>
            <div class="sec-layer"><span class="sec-layer-ico" data-dots="1110110001101011001011101" data-size="38"></span><span><span class="sec-layer-t">Physical safeguards</span><span class="sec-layer-d" style="display:block;">Appropriate to handling PHI</span></span></div>
            <div class="sec-layer"><span class="sec-layer-ico" data-dots="0010001010101010111000100" data-size="38"></span><span><span class="sec-layer-t">Assistive, provider-confirmed AI</span><span class="sec-layer-d" style="display:block;">Consistent with responsible clinical use</span></span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== AI GOVERNANCE ===================================================== -->
  <section class="section bg-navy" id="ai-governance" aria-labelledby="aigov-h">
    <div class="dot-field" aria-hidden="true" style="opacity:.1;"></div>
    <div class="container">
      <div class="sec-band-grid">
        <div class="sec-band-copy" data-reveal>
          <span class="eyebrow">AI governance &amp; safety</span>
          <h2 id="aigov-h">Security includes keeping AI in its lane.</h2>
          <p class="lead">In Tavali, security is also about control over automation. AI agents act only within defined trust-tier limits, and any clinical action is held for provider approval through a non-overridable safeguard — so automation never overrides clinical judgment.</p>
        </div>
        <div class="sec-band-visual" data-reveal data-delay="1">
          <div class="sec-lock-card">
            <div class="dot-field" aria-hidden="true" style="opacity:.12;"></div>
            <div style="position:relative;z-index:2;">
              <div class="sec-lock-ring">
                <svg width="40" height="40" viewBox="0 0 40 40" aria-hidden="true"><rect x="10" y="18" width="20" height="15" rx="3" fill="none" stroke="#7FA8D3" stroke-width="2.2"/><path d="M14 18v-4a6 6 0 0 1 12 0v4" fill="none" stroke="#7FA8D3" stroke-width="2.2"/><circle cx="20" cy="25" r="2.4" fill="#7FA8D3"/></svg>
              </div>
              <div class="sec-lock-tiers">
                <div class="sec-tier"><span class="dot auto" aria-hidden="true"></span><span><strong>Autonomous</strong> — routine, low-risk tasks run on their own</span></div>
                <div class="sec-tier"><span class="dot assist" aria-hidden="true"></span><span><strong>Assistive</strong> — AI drafts and suggests; staff confirm</span></div>
                <div class="sec-tier"><span class="dot locked" aria-hidden="true"></span><span><strong>Provider-locked</strong> — clinical actions need provider approval</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== COMMITMENT ===================================================== -->
  <section class="section bg-navy" id="commitment" aria-labelledby="commit-h" style="padding-top:0;">
    <div class="container">
      <div class="sec-visual" style="background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.12);box-shadow:none;text-align:center;padding:clamp(2.5rem,5vw,3.5rem);" data-reveal>
        <span class="eyebrow" style="justify-content:center;">Our commitment</span>
        <h2 id="commit-h" style="color:#fff;font-size:clamp(1.6rem,3.2vw,2.3rem);margin-top:.85rem;max-width:18ch;margin-inline:auto;">Our commitment as we scale.</h2>
        <p class="lead" style="margin:1.05rem auto 0;max-width:60ch;">Tavali is committed to pursuing industry-standard security practices and recognized attestations as the company grows, and to evolving its security and compliance program alongside the practices and organizations it serves.</p>
        <span class="commit-note"><span class="pip" aria-hidden="true"></span> An ongoing commitment — not a finish line</span>
      </div>
    </div>
  </section>

  <!-- ===================================================== SECURITY FAQ ===================================================== -->
  <section class="section bg-surface" id="faq" aria-labelledby="faq-h">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow" data-reveal>Security FAQ</span>
        <h2 id="faq-h" data-reveal data-delay="1">Common security &amp; compliance questions.</h2>
        <p class="lead" data-reveal data-delay="2">Straight answers about how Tavali protects data, supports HIPAA-aligned operations, and governs its AI.</p>
      </div>
      <div class="faq-wrap" data-reveal>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>Is Tavali secure?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Tavali is built with privacy-by-design, encryption, access controls, and audit logging to protect patient data.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>Does Tavali support HIPAA-aligned operations?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Yes. Tavali is designed to support HIPAA-aligned workflows with administrative, technical, and physical safeguards appropriate to protected health information.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>How does Tavali protect data across multiple locations?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Tavali is built to isolate each organization&rsquo;s data and enforce role-based access, including across multi-location deployments.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>Can Tavali&rsquo;s AI take clinical action without approval?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>No. Clinical actions are held for provider approval through a non-overridable safeguard; only routine, low-risk tasks can run autonomously.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>Who can access patient data in Tavali?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Tavali is designed to enforce role-based access controls so users can access only the data they are authorized to see.</p></div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== FINAL CTA ===================================================== -->
  <section class="section bg-navy final-cta" id="security-cta" aria-labelledby="final-h">
    <div class="hero-glow" aria-hidden="true" style="left:50%;top:-30%;transform:translateX(-50%);"></div>
    <div class="dot-field" aria-hidden="true" style="opacity:.1;-webkit-mask-image:radial-gradient(ellipse 70% 100% at 50% 0,#000,transparent 70%);mask-image:radial-gradient(ellipse 70% 100% at 50% 0,#000,transparent 70%);"></div>
    <div class="container final-cta-inner">
      <h2 id="final-h" data-reveal>Have security or compliance questions?</h2>
      <p class="lead" data-reveal data-delay="1">Talk to our team — we&rsquo;ll walk your IT, clinical, and legal stakeholders through how Tavali protects patient data.</p>
      <div class="final-cta-row" data-reveal data-delay="2">
        <a class="btn btn--primary btn--lg" href="#">Talk to Our Team <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        <a class="btn btn--ghost btn--lg" href="/faq">Read the FAQ</a>
      </div>
    </div>
  </section>

</main>
</BaseLayout>
