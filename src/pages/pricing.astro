---
/**
 * pricing.astro — migrated from "Pricing.html".
 * Static marketing/content page. Shared chrome (head, header, nav, footer) is
 * provided by BaseLayout; this file holds the page-unique <main> body and its
 * structured data. Generated by scripts/migrate-pages.mjs, then maintained by
 * hand.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/styles-pricing.css';
---
<BaseLayout
  title="Tavali Pricing — Plans for Every Dental Practice"
  description="Tavali pricing is subscription-based and priced per location, modular so you start with what you need and expand as you grow. Plans scale from a single office to a multi-location DSO — book a demo for a custom quote."
  canonical="https://www.tavali.com/pricing/"
  ogDescription="Subscription pricing, per location, modular. Plans scale from a single office to a multi-location DSO. Book a demo for a quote built around your needs."
  ogImage="https://www.tavali.com/og-pricing.png"
  ogImageAlt="Tavali pricing — plans that scale with your dental practice."
  thumbnailLabel="Pricing"
>
  <Fragment slot="jsonld" set:html={`<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": "https://www.tavali.com/pricing/#product",
  "name": "Tavali",
  "description": "Tavali is an AI-native operating system for dental practices, priced as a subscription per location, modular and scaling with organization type. Pricing is quote-based.",
  "brand": { "@type": "Brand", "name": "Tavali" },
  "category": "Dental Practice Management & Clinical AI Software",
  "offers": {
    "@type": "Offer",
    "url": "https://www.tavali.com/pricing/",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "priceCurrency": "USD",
      "valueAddedTaxIncluded": false,
      "description": "Custom, quote-based subscription pricing billed per location and tailored to the practice's size, modules, and organization type. Contact Tavali for a quote."
    },
    "seller": { "@type": "Organization", "name": "Tavali, Inc." }
  }
}
</script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": "https://www.tavali.com/pricing/#faq",
  "url": "https://www.tavali.com/pricing/",
  "inLanguage": "en-US",
  "mainEntity": [
    { "@type": "Question", "name": "How much does Tavali cost?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali is subscription-based, priced per location, and modular, with your exact pricing provided through a custom quote after a demo." } },
    { "@type": "Question", "name": "How is Tavali priced?", "acceptedAnswer": { "@type": "Answer", "text": "Pricing is per location and modular: you start with the horizons and agents you need and expand on the same platform over time." } },
    { "@type": "Question", "name": "Is there a free trial or demo?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali offers a personalized demo where you can see the platform applied to your practice; book a demo to get started." } },
    { "@type": "Question", "name": "Does pricing scale for groups, DSOs, and franchises?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Plans scale from a single office to multi-location groups, DSOs, and franchises, with centralized governance for larger organizations." } },
    { "@type": "Question", "name": "Can I start small and add more later?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Tavali is modular, so you can begin with one or two high-impact areas and expand across the platform without switching systems." } },
    { "@type": "Question", "name": "What’s included in every plan?", "acceptedAnswer": { "@type": "Answer", "text": "Every plan includes the core AI-native platform, enterprise-grade security and privacy, onboarding, and ongoing support; tiers differ in scope and scale." } }
  ]
}
</script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": "https://www.tavali.com/pricing/#breadcrumb",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.tavali.com/" },
    { "@type": "ListItem", "position": 2, "name": "Pricing", "item": "https://www.tavali.com/pricing/" }
  ]
}
</script>`} />

<main id="main">

  <!-- ===================================================== HERO ===================================================== -->
  <section class="hero hero--pricing" aria-labelledby="page-h">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-bg-dots"></div>
      <div class="hero-glow"></div>
    </div>
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li class="sep" aria-hidden="true">/</li>
          <li><span aria-current="page">Pricing</span></li>
        </ol>
      </nav>
      <div class="hero-grid">
        <div class="hero-copy">
          <span class="eyebrow" data-reveal>Pricing</span>
          <h1 id="page-h" data-reveal data-delay="1">Pricing</h1>
          <p class="hero-def" data-reveal data-delay="1">Tavali pricing is <span class="accent">subscription-based and priced per location</span>, modular so you start with what you need and expand as you grow — with your exact pricing quoted through a demo.</p>
          <p class="hero-sub" data-reveal data-delay="2">No rip-and-replace, no surprises. Plans scale with your practice — from a single office to a multi-location DSO. Book a demo for a quote built around your needs.</p>
          <div class="hero-cta" data-reveal data-delay="3">
            <a class="btn btn--primary btn--hero" href="#pricing-cta">Book a Demo <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a class="btn btn--ghost btn--lg" href="#pricing-cta">Talk to Sales</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== HOW PRICING WORKS ===================================================== -->
  <section class="section" id="how" aria-labelledby="how-h">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow">The model</span>
        <h2 id="how-h">How Tavali pricing works.</h2>
        <p class="lead">Tavali is a subscription priced per location and built modularly — you start with the capabilities you need most and expand on the same platform over time.</p>
      </div>
      <div class="how-grid">
        <article class="how-card" data-reveal><span class="how-ico" data-dots="0010001010100010101000100" data-size="48" aria-hidden="true"></span><h3>Per location</h3><p>You&rsquo;re priced by location, so pricing scales naturally as your organization grows.</p></article>
        <article class="how-card" data-reveal data-delay="1"><span class="how-ico" data-dots="1000100000002000000010001" data-size="48" aria-hidden="true"></span><h3>Modular</h3><p>Start with the horizons and agents you need most, and add more over time on the same platform.</p></article>
        <article class="how-card" data-reveal data-delay="2"><span class="how-ico" data-dots="0000011011110111121111011" data-size="48" aria-hidden="true"></span><h3>Scales with your org type</h3><p>From single offices to groups, DSOs, and franchises, the plan fits how you operate.</p></article>
        <article class="how-card" data-reveal data-delay="3"><span class="how-ico" data-dots="1111010001102011000101111" data-size="48" aria-hidden="true"></span><h3>One platform, one bill</h3><p>Replace the cost and complexity of four-to-seven separate tools with a single subscription.</p></article>
      </div>
    </div>
  </section>

  <!-- ===================================================== PLAN TIERS ===================================================== -->
  <section class="section bg-surface" id="plans" aria-labelledby="plans-h">
    <div class="container">
      <div class="section-head center" data-reveal>
        <span class="eyebrow">Plans</span>
        <h2 id="plans-h">Plans that scale with your practice.</h2>
        <p class="lead">Four tiers mapped to how you operate — every one priced with a custom quote, so you only pay for the locations and modules you run.</p>
      </div>
      <div class="tier-grid">

        <article class="tier" data-reveal aria-labelledby="tier-ess">
          <div class="tier-name" id="tier-ess">Essentials</div>
          <p class="tier-for">Single offices getting started with an AI-native platform.</p>
          <div class="tier-price"><span class="pl">Custom</span><span class="ps">— book a demo</span></div>
          <p class="tier-incl-label">Includes</p>
          <ul class="tier-incl">
            <li><svg class="ck" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8.5l3.2 3.2L13 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Core platform (PMS/EHR, Front Office)</span></li>
            <li><svg class="ck" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8.5l3.2 3.2L13 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Clinical AI scribe</span></li>
            <li><svg class="ck" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8.5l3.2 3.2L13 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Core AI agents</span></li>
            <li><svg class="ck" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8.5l3.2 3.2L13 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Standard support &amp; onboarding</span></li>
          </ul>
          <a class="btn btn--ghost" href="#pricing-cta">Book a Demo</a>
        </article>

        <article class="tier tier--popular" data-reveal data-delay="1" aria-labelledby="tier-growth">
          <div class="tier-name" id="tier-growth">Growth</div>
          <p class="tier-for">Growing practices and small groups ready to run more on AI.</p>
          <div class="tier-price"><span class="pl">Custom</span><span class="ps">— book a demo</span></div>
          <p class="tier-incl-label">Includes</p>
          <ul class="tier-incl">
            <li><svg class="ck" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8.5l3.2 3.2L13 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Everything in Essentials</span></li>
            <li><svg class="ck" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8.5l3.2 3.2L13 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Intelligence &amp; denial-prevention</span></li>
            <li><svg class="ck" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8.5l3.2 3.2L13 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Diagnostics</span></li>
            <li><svg class="ck" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8.5l3.2 3.2L13 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Expanded agent suite</span></li>
            <li><svg class="ck" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8.5l3.2 3.2L13 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Priority support</span></li>
          </ul>
          <a class="btn btn--primary" href="#pricing-cta">Book a Demo</a>
        </article>

        <article class="tier" data-reveal data-delay="2" aria-labelledby="tier-ent">
          <div class="tier-name" id="tier-ent">Enterprise / DSO</div>
          <p class="tier-for">DSOs, franchises, and multi-location groups needing scale and governance.</p>
          <div class="tier-price"><span class="pl">Custom</span><span class="ps">— talk to sales</span></div>
          <p class="tier-incl-label">Includes</p>
          <ul class="tier-incl">
            <li><svg class="ck" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8.5l3.2 3.2L13 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Everything in Growth</span></li>
            <li><svg class="ck" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8.5l3.2 3.2L13 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Multi-location governance &amp; central policy</span></li>
            <li><svg class="ck" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8.5l3.2 3.2L13 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Portfolio analytics</span></li>
            <li><svg class="ck" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8.5l3.2 3.2L13 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Advanced security &amp; compliance</span></li>
            <li><svg class="ck" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8.5l3.2 3.2L13 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Dedicated success management</span></li>
          </ul>
          <a class="btn btn--ghost" href="#pricing-cta">Talk to Sales</a>
        </article>

        <article class="tier" data-reveal data-delay="3" aria-labelledby="tier-custom">
          <div class="tier-name" id="tier-custom">Custom</div>
          <p class="tier-for">Organizations with specific needs.</p>
          <div class="tier-price"><span class="pl">Custom</span><span class="ps">— get a quote</span></div>
          <p class="tier-incl-label">Includes</p>
          <ul class="tier-incl">
            <li><svg class="ck" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8.5l3.2 3.2L13 5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg><span>A plan configured to your locations, modules, and goals</span></li>
          </ul>
          <a class="btn btn--ghost" href="#pricing-cta">Get a Quote</a>
        </article>

      </div>
    </div>
  </section>

  <!-- ===================================================== FOUNDATION ===================================================== -->
  <section class="section" id="foundation" aria-labelledby="foundation-h">
    <div class="container">
      <div class="section-head" data-reveal style="max-width:760px;">
        <span class="eyebrow">Included in every plan</span>
        <h2 id="foundation-h">Every plan is built on the same foundation.</h2>
        <p class="lead">Every Tavali customer gets the core AI-native platform, enterprise-grade security and privacy, guided onboarding, and ongoing support. Tiers differ in scope and scale — not in quality or trust.</p>
      </div>
      <div class="foundation-grid">
        <div class="foundation" data-reveal><span class="foundation-ico" data-dots="0010001110111110111000100" data-size="40" aria-hidden="true"></span><div><h3>The core platform</h3><p>The full AI-native operating system, on one data layer.</p></div></div>
        <div class="foundation" data-reveal data-delay="1"><span class="foundation-ico" data-dots="1111110001100011000111111" data-size="40" aria-hidden="true"></span><div><h3>Security &amp; privacy</h3><p>Enterprise-grade protection, built in from day one.</p></div></div>
        <div class="foundation" data-reveal data-delay="2"><span class="foundation-ico" data-dots="0100010101010101010100010" data-size="40" aria-hidden="true"></span><div><h3>Guided onboarding</h3><p>We help your team get up and running.</p></div></div>
        <div class="foundation" data-reveal data-delay="3"><span class="foundation-ico" data-dots="0010001010001110100010100" data-size="40" aria-hidden="true"></span><div><h3>Ongoing support</h3><p>Help when you need it, at every tier.</p></div></div>
      </div>
    </div>
  </section>

  <!-- ===================================================== VALUE / ROI ===================================================== -->
  <section class="section bg-navy value" id="value" aria-labelledby="value-h">
    <div class="dot-field" aria-hidden="true" style="opacity:.1;"></div>
    <div class="container">
      <div class="value-grid">
        <div data-reveal>
          <span class="eyebrow">Value</span>
          <h2 id="value-h">Priced against the <span class="hl">cost of doing nothing.</span></h2>
          <p class="lead">The real question isn&rsquo;t what Tavali costs — it&rsquo;s what the status quo is already costing you. Tavali is designed to pay for itself by recovering revenue lost to claim denials, inaccurate coding, missed care, and administrative drag, while reducing your reliance on hard-to-hire staff. Weigh the subscription against the leak it&rsquo;s built to close.</p>
        </div>
        <div data-reveal data-delay="1">
          <div class="value-metrics">
            <div class="vm"><div class="n"><span class="dir">↓</span>45%</div><div class="l">Claim denials</div></div>
            <div class="vm"><div class="n"><span class="dir">↓</span>60%</div><div class="l">Documentation time</div></div>
            <div class="vm"><div class="n">120<span style="font-size:1.1rem;">+</span></div><div class="l">Admin hours saved / month</div></div>
            <div class="vm"><div class="n"><span class="dir">↑</span>25%</div><div class="l">Case acceptance</div></div>
          </div>
          <p class="value-note">Target outcomes / design objectives.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== PRICING FAQ ===================================================== -->
  <section class="section bg-surface" id="faq" aria-labelledby="faq-h">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow" data-reveal>Pricing FAQ</span>
        <h2 id="faq-h" data-reveal data-delay="1">How much does Tavali cost?</h2>
        <p class="lead" data-reveal data-delay="2">Straight answers about how Tavali is priced, what&rsquo;s included, and how to get a quote.</p>
      </div>
      <div class="faq-wrap" data-reveal>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><span>How much does Tavali cost?</span><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Tavali is subscription-based, priced per location, and modular, with your exact pricing provided through a custom quote after a demo.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><span>How is Tavali priced?</span><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Pricing is per location and modular: you start with the horizons and agents you need and expand on the same platform over time.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><span>Is there a free trial or demo?</span><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Tavali offers a personalized demo where you can see the platform applied to your practice; book a demo to get started.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><span>Does pricing scale for groups, DSOs, and franchises?</span><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Yes. Plans scale from a single office to multi-location groups, DSOs, and franchises, with centralized governance for larger organizations.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><span>Can I start small and add more later?</span><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Yes. Tavali is modular, so you can begin with one or two high-impact areas and expand across the platform without switching systems.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><span>What&rsquo;s included in every plan?</span><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Every plan includes the core AI-native platform, enterprise-grade security and privacy, onboarding, and ongoing support; tiers differ in scope and scale.</p></div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== FINAL CTA ===================================================== -->
  <section class="section bg-navy final-cta" id="pricing-cta" aria-labelledby="final-h">
    <div class="hero-glow" aria-hidden="true" style="left:50%;top:-30%;transform:translateX(-50%);"></div>
    <div class="dot-field" aria-hidden="true" style="opacity:.1;-webkit-mask-image:radial-gradient(ellipse 70% 100% at 50% 0,#000,transparent 70%);mask-image:radial-gradient(ellipse 70% 100% at 50% 0,#000,transparent 70%);"></div>
    <div class="container final-cta-inner">
      <h2 id="final-h" data-reveal>Get pricing built for your practice.</h2>
      <p class="lead" data-reveal data-delay="1">Book a 30-minute demo and we&rsquo;ll put together a quote around your locations, modules, and goals.</p>
      <div class="final-cta-row" data-reveal data-delay="2">
        <a class="btn btn--primary btn--lg" href="#">Book a Demo <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        <a class="btn btn--ghost btn--lg" href="/platform">Explore the Platform</a>
      </div>
    </div>
  </section>

</main>
</BaseLayout>
