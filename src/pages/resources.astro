---
/**
 * resources.astro — migrated from "Resources.html".
 * Static marketing/content page. Shared chrome (head, header, nav, footer) is
 * provided by BaseLayout; this file holds the page-unique <main> body and its
 * structured data. Generated by scripts/migrate-pages.mjs, then maintained by
 * hand.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/styles-resources.css';
---
<BaseLayout
  title="Tavali Resources — Dental AI Guides, FAQ &amp; Security"
  description="Tavali Resources is your hub for understanding how an AI-native operating system works for dental practices — from answers to common questions to how we protect patient data, plus guides and insights on AI in dentistry."
  canonical="https://www.tavali.com/resources/"
  ogDescription="Guides, answers, and the thinking behind the platform. Start with our FAQ or learn how Tavali keeps your data secure."
  ogImage="https://www.tavali.com/og-resources.png"
  ogImageAlt="Tavali Resources — guides, FAQ, and security for an AI-native dental platform."
  thumbnailLabel="Resources"
>
  <Fragment slot="jsonld" set:html={`<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": "https://www.tavali.com/resources/#breadcrumb",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.tavali.com/" },
    { "@type": "ListItem", "position": 2, "name": "Resources", "item": "https://www.tavali.com/resources/" }
  ]
}
</script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "@id": "https://www.tavali.com/resources/#categories",
  "name": "Tavali Resources",
  "description": "Tavali resource categories: FAQ, Security & Compliance, Blog, Guides, and Patents & IP.",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "FAQ", "url": "https://www.tavali.com/resources/faq/" },
    { "@type": "ListItem", "position": 2, "name": "Security & Compliance", "url": "https://www.tavali.com/resources/security/" },
    { "@type": "ListItem", "position": 3, "name": "Blog", "url": "https://www.tavali.com/blog/" },
    { "@type": "ListItem", "position": 4, "name": "Guides", "url": "https://www.tavali.com/resources/guides/" },
    { "@type": "ListItem", "position": 5, "name": "Patents & IP", "url": "https://www.tavali.com/resources/patents/" }
  ]
}
</script>`} />

<main id="main">

  <!-- ===================================================== HERO ===================================================== -->
  <section class="hero hero--resources" aria-labelledby="page-h">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-bg-dots"></div>
      <canvas class="hero-canvas"></canvas>
      <div class="hero-glow"></div>
    </div>
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li class="sep" aria-hidden="true">/</li>
          <li><span aria-current="page">Resources</span></li>
        </ol>
      </nav>
      <div class="hero-grid">
        <div class="hero-copy">
          <span class="eyebrow" data-reveal>Resources</span>
          <h1 id="page-h" data-reveal data-delay="1">Resources</h1>
          <p class="hero-def" data-reveal data-delay="1">Tavali Resources is your hub for understanding how an <span class="accent">AI-native operating system</span> works for dental practices — from answers to common questions to how we protect patient data.</p>
          <p class="hero-sub" data-reveal data-delay="2">Guides, answers, and the thinking behind the platform. Start with our FAQ or learn how Tavali keeps your data secure.</p>
          <div class="hero-cta" data-reveal data-delay="3">
            <a class="btn btn--primary btn--hero" href="#resources-cta">Book a Demo <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a class="btn btn--ghost btn--lg" href="/faq">Read the FAQ</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== CATEGORY GRID ===================================================== -->
  <section class="section" id="categories" aria-labelledby="cat-h">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Browse by category</span>
        <h2 id="cat-h">Everything you need to understand Tavali.</h2>
        <p class="lead">Explore answers, security practices, and — soon — guides and insights on AI in dentistry. Each area is one connected part of the same platform story.</p>
      </div>
      <div class="res-grid">

        <a class="res-card" id="cat-faq" href="/faq">
          <div class="res-head">
            <span class="res-ico" data-dots="0111010001102011000101110" data-size="44"></span>
            <span class="res-tag res-tag--live">Live</span>
          </div>
          <h3>FAQ</h3>
          <p>Answers to the most common questions about Tavali, the platform, pricing, and security.</p>
          <span class="res-link">Read the FAQ <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        </a>

        <a class="res-card" id="cat-security" href="/security">
          <div class="res-head">
            <span class="res-ico" data-dots="0010001110111110111000100" data-size="44"></span>
            <span class="res-tag res-tag--live">Live</span>
          </div>
          <h3>Security &amp; Compliance</h3>
          <p>How Tavali protects patient data and supports HIPAA-aligned operations.</p>
          <span class="res-link">See our security practices <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        </a>

        <div class="res-card res-card--soon" id="cat-blog">
          <div class="res-head">
            <span class="res-ico" data-dots="1111010001102011000101111" data-size="44"></span>
            <span class="res-tag res-tag--soon">Coming soon</span>
          </div>
          <h3>Blog</h3>
          <p>Insights on AI in dentistry, practice operations, and revenue.</p>
          <span class="res-link res-link--soon">In the works</span>
        </div>

        <div class="res-card res-card--soon" id="cat-guides">
          <div class="res-head">
            <span class="res-ico" data-dots="1111100000111110000011111" data-size="44"></span>
            <span class="res-tag res-tag--soon">Coming soon</span>
          </div>
          <h3>Guides</h3>
          <p>Practical guides on reducing denials, cutting documentation time, and solving staffing strain.</p>
          <span class="res-link res-link--soon">In the works</span>
        </div>

        <div class="res-card res-card--soon" id="cat-patents">
          <div class="res-head">
            <span class="res-ico" data-dots="1000001110011100111000001" data-size="44"></span>
            <span class="res-tag res-tag--soon">Coming soon</span>
          </div>
          <h3>Patents &amp; IP</h3>
          <p>Tavali's proprietary, patent-pending technology and innovation.</p>
          <span class="res-link res-link--soon">In the works</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ===================================================== FEATURED / START HERE ===================================================== -->
  <section class="section bg-surface" id="start-here" aria-labelledby="start-h">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Start here</span>
        <h2 id="start-h">Two resources worth reading first.</h2>
        <p class="lead">If you only have a few minutes, these answer the questions buyers ask most — what Tavali does, and how it keeps patient data safe.</p>
      </div>
      <div class="feature-grid">
        <article class="feature" data-reveal>
          <div class="dot-field" aria-hidden="true"></div>
          <div class="feature-body">
            <span class="feature-kicker">FAQ</span>
            <h3>Get straight answers about Tavali.</h3>
            <p>The fastest way to understand what an AI-native dental operating system actually is — covering the platform, governance, pricing, and security in plain language.</p>
            <a class="btn btn--primary" href="/faq">Read the FAQ <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
          </div>
        </article>
        <article class="feature" data-reveal data-delay="1">
          <div class="dot-field" aria-hidden="true"></div>
          <div class="feature-body">
            <span class="feature-kicker">Security &amp; Compliance</span>
            <h3>See how we protect patient data.</h3>
            <p>Tavali is built for HIPAA-aligned operations, with provider-governed AI and safeguards designed for a clinical environment from day one.</p>
            <a class="btn btn--primary" href="/security">Explore security <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ===================================================== NEWSLETTER ===================================================== -->
  <section class="section--tight" aria-labelledby="news-h">
    <div class="container">
      <div class="news-band" data-reveal>
        <div class="news-band-text">
          <h3 id="news-h">Be the first to read what's next.</h3>
          <p>Get notified when our Blog and Guides launch — practical insight on AI in dentistry, no noise.</p>
        </div>
        <form class="news-row" novalidate>
          <label for="news-email-2" style="position:absolute;left:-9999px;">Email address</label>
          <input id="news-email-2" type="email" placeholder="Work email" autocomplete="email" />
          <button type="submit">Notify me</button>
        </form>
      </div>
    </div>
  </section>

  <!-- ===================================================== FINAL CTA ===================================================== -->
  <section class="section bg-navy final-cta" id="resources-cta" aria-labelledby="final-h">
    <div class="hero-glow" aria-hidden="true" style="left:50%;top:-30%;transform:translateX(-50%);"></div>
    <div class="dot-field" aria-hidden="true" style="opacity:.1;-webkit-mask-image:radial-gradient(ellipse 70% 100% at 50% 0,#000,transparent 70%);mask-image:radial-gradient(ellipse 70% 100% at 50% 0,#000,transparent 70%);"></div>
    <div class="container final-cta-inner">
      <h2 id="final-h" data-reveal>Have a question we haven't answered yet?</h2>
      <p class="lead" data-reveal data-delay="1">Book a 30-minute demo and we'll walk your team through Tavali — and answer whatever the resources didn't.</p>
      <div class="final-cta-row" data-reveal data-delay="2">
        <a class="btn btn--primary btn--lg" href="#">Book a Demo <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        <a class="btn btn--ghost btn--lg" href="/platform">Explore the Platform</a>
      </div>
    </div>
  </section>

</main>
</BaseLayout>
