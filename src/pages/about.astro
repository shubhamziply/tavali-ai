---
/**
 * about.astro — migrated from "About.html".
 * Static marketing/content page. Shared chrome (head, header, nav, footer) is
 * provided by BaseLayout; this file holds the page-unique <main> body and its
 * structured data. Generated by scripts/migrate-pages.mjs, then maintained by
 * hand.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/styles-about.css';
---
<BaseLayout
  title="About Tavali — The AI-Native Dental Operating System"
  description="Tavali is building the AI-native operating system for dental practices — founded by a practicing dentist and a repeat technology founder who lived the problems it solves. Learn our mission, why we exist, what we believe, and where we're going."
  canonical="https://www.tavali.com/company/about/"
  ogDescription="We're building the AI-native operating system for dental practices, founded by people who have lived the problems it solves — so clinicians spend more time on patients and less on software."
  ogImage="https://www.tavali.com/og-about.png"
  ogImageAlt="About Tavali — the AI-native operating system for dental practices."
  thumbnailLabel="About"
>
  <Fragment slot="jsonld" set:html={`<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://www.tavali.com/#organization",
  "name": "Tavali, Inc.",
  "url": "https://www.tavali.com/",
  "logo": {
    "@type": "ImageObject",
    "url": "https://www.tavali.com/logo.png",
    "width": 2015,
    "height": 720
  },
  "slogan": "The AI-native operating system for dental practices.",
  "description": "Tavali is an AI-native operating system for dental practices that unifies clinical care, operations, and revenue into a single, AI-driven platform. It was founded by a practicing dentist and practice owner alongside a repeat technology founder.",
  "foundingDate": "2025",
  "founders": [
    {
      "@type": "Person",
      "name": "Mehrak Assadian",
      "jobTitle": "Co-Founder & CEO"
    },
    {
      "@type": "Person",
      "name": "Anil Jwalanna",
      "jobTitle": "Co-Founder & CTO"
    }
  ],
  "knowsAbout": [
    "AI-native dental operating system",
    "Dental practice management",
    "Clinical AI",
    "Dental claim denial prevention",
    "Dental revenue cycle management"
  ],
  "sameAs": [
    "https://www.linkedin.com/company/tavali",
    "https://x.com/tavali"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "Sales",
    "email": "hello@tavali.com",
    "areaServed": "US",
    "availableLanguage": "English"
  }
}
</script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": "https://www.tavali.com/company/about/#breadcrumb",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.tavali.com/" },
    { "@type": "ListItem", "position": 2, "name": "Company", "item": "https://www.tavali.com/company/" },
    { "@type": "ListItem", "position": 3, "name": "About", "item": "https://www.tavali.com/company/about/" }
  ]
}
</script>`} />

<main id="main">

  <!-- ===================================================== HERO ===================================================== -->
  <section class="hero hero--about" aria-labelledby="page-h">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-bg-dots"></div>
      <canvas class="hero-canvas"></canvas>
      <div class="hero-glow"></div>
    </div>
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li class="sep" aria-hidden="true">/</li>
          <li><span class="crumb-static">Company</span></li>
          <li class="sep" aria-hidden="true">/</li>
          <li><span aria-current="page">About</span></li>
        </ol>
      </nav>
      <div class="hero-grid">
        <div class="hero-copy">
          <span class="eyebrow" data-reveal>About Tavali</span>
          <h1 id="page-h" data-reveal data-delay="1">About Tavali</h1>
          <p class="hero-def" data-reveal data-delay="1">Tavali exists to give dental practices one intelligent platform to run on — so clinicians spend more time on <span class="accent">patients</span> and less on software.</p>
          <p class="hero-sub" data-reveal data-delay="2">We&rsquo;re building the AI-native operating system for dental practices, founded by people who have lived the problems it solves.</p>
          <div class="hero-cta" data-reveal data-delay="3">
            <a class="btn btn--primary btn--hero" href="#about-cta">Book a Demo <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a class="btn btn--ghost btn--lg" href="/team">Meet the Team</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== MISSION ===================================================== -->
  <section class="section" id="mission" aria-labelledby="mission-h">
    <div class="container">
      <div class="statement">
        <span class="eyebrow" data-reveal>Our mission</span>
        <h2 id="mission-h" class="statement-lead" data-reveal data-delay="1">Tavali&rsquo;s mission is to modernize how dental practices operate by replacing fragmented, legacy software with a single, <span class="accent">AI-native platform</span> that unifies clinical care, operations, and revenue.</h2>
        <p class="statement-body" data-reveal data-delay="2">We believe a dental practice should run on one intelligent system that does the work — not on a patchwork of disconnected tools that create more of it.</p>
      </div>
    </div>
  </section>

  <!-- ===================================================== ORIGIN STORY ===================================================== -->
  <section class="section bg-surface" id="origin" aria-labelledby="origin-h">
    <div class="container">
      <div class="origin-grid">
        <div class="origin-copy">
          <span class="eyebrow" data-reveal>Our origin</span>
          <h2 id="origin-h" data-reveal data-delay="1">Why we built Tavali</h2>
          <p class="origin-kicker" data-reveal data-delay="1">Tavali began with a problem its founders knew intimately.</p>
          <p class="body" data-reveal data-delay="2">One co-founder has spent more than fifteen years as a dentist and practice owner — living the daily reality of stitched-together software, staffing shortages, denied claims, and hours lost to documentation. The other has spent a career building and scaling AI and software companies.</p>
          <p class="body" data-reveal data-delay="2">Together they saw the same thing from two sides: dentistry was being handed AI as a scatter of disconnected point tools, when what practices actually needed was a platform built around AI from the ground up — one that could carry a clinical finding all the way through to a paid claim, keep clinicians in control, and let a smaller team do more.</p>
          <span class="origin-close" data-reveal data-delay="3"><span class="pip" aria-hidden="true"></span> Tavali is that platform.</span>
        </div>

        <div class="origin-visual" data-reveal data-delay="2" aria-hidden="true">
          <div class="dot-field"></div>
          <p class="ov-lbl">Two founders · one conviction</p>
          <div class="origin-lane">
            <span class="ol-ico" data-dots="0010001110111110111000100" data-size="26"></span>
            <span><span class="ol-t">Chairside reality</span><span class="ol-d">15+ years as a dentist &amp; practice owner</span></span>
          </div>
          <div class="origin-lane">
            <span class="ol-ico" data-dots="1000101110112110111010001" data-size="26"></span>
            <span><span class="ol-t">Built &amp; scaled in tech</span><span class="ol-d">A career building AI &amp; software companies</span></span>
          </div>
          <p class="origin-merge">↓ converged into</p>
          <div class="origin-result">
            <svg width="20" height="20" viewBox="0 0 52 52" aria-hidden="true"><circle cx="6" cy="6" r="4" fill="#fff"/><circle cx="46" cy="6" r="4" fill="#fff"/><circle cx="26" cy="26" r="4" fill="#fff"/><circle cx="26" cy="6" r="4" fill="#fff" fill-opacity=".4"/><circle cx="46" cy="26" r="4" fill="#fff" fill-opacity=".4"/><circle cx="6" cy="26" r="4" fill="#fff" fill-opacity=".4"/></svg>
            One AI-native platform
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== VALUES ===================================================== -->
  <section class="section" id="values" aria-labelledby="values-h">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow" data-reveal>What we believe</span>
        <h2 id="values-h" data-reveal data-delay="1">The principles we build on.</h2>
        <p class="lead" data-reveal data-delay="2">Five convictions shape every decision we make — about the product, the company, and the practices we serve.</p>
      </div>
      <div class="values-grid">
        <article class="val-card" data-reveal>
          <span class="val-ico" data-dots="0010001110111110102110101" data-size="52"></span>
          <h3>Practices first</h3>
          <p>Every decision starts with whether it makes a real dental practice run better.</p>
        </article>
        <article class="val-card" data-reveal data-delay="1">
          <span class="val-ico" data-dots="1000101110112110111010001" data-size="52"></span>
          <h3>AI-native, not bolted on</h3>
          <p>We build around AI from the ground up, because retrofitting it onto legacy software can&rsquo;t deliver the same result.</p>
        </article>
        <article class="val-card" data-reveal data-delay="2">
          <span class="val-ico" data-dots="0010001110112110111000100" data-size="52"></span>
          <h3>Clinicians stay in control</h3>
          <p>Automation should remove busywork, never override clinical judgment.</p>
        </article>
        <article class="val-card" data-reveal data-delay="1">
          <span class="val-ico" data-dots="1000101010002000101010001" data-size="52"></span>
          <h3>Connected beats fragmented</h3>
          <p>The value is in one connected workflow, not another standalone tool.</p>
        </article>
        <article class="val-card" data-reveal data-delay="2">
          <span class="val-ico" data-dots="0111010001102011000101110" data-size="52"></span>
          <h3>Built to earn trust</h3>
          <p>We treat patient data, safety, and clinical responsibility with the seriousness they demand.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ===================================================== LEADERSHIP ===================================================== -->
  <section class="section bg-surface" id="leadership" aria-labelledby="leadership-h">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow" data-reveal>Leadership</span>
        <h2 id="leadership-h" data-reveal data-delay="1">Led by people who know dentistry and how to build.</h2>
        <p class="lead" data-reveal data-delay="2">Tavali is founded by two people who saw the same problem from opposite sides of the chair.</p>
      </div>
      <div class="lead-grid">
        <article class="founder-card" data-reveal>
          <div class="founder-mono" aria-hidden="true"><div class="dot-field"></div><span>MA</span></div>
          <div>
            <h3 class="fc-name">Mehrak Assadian</h3>
            <p class="fc-title">Co-Founder &amp; CEO</p>
            <p class="fc-cred">A doctor, dental-practice owner of 15+ years, and dental strategy consultant who lives the problems Tavali solves.</p>
          </div>
        </article>
        <article class="founder-card" data-reveal data-delay="1">
          <div class="founder-mono" aria-hidden="true"><div class="dot-field"></div><span>AJ</span></div>
          <div>
            <h3 class="fc-name">Anil Jwalanna</h3>
            <p class="fc-title">Co-Founder &amp; CTO</p>
            <p class="fc-cred">A 5x founder and technology executive who has built, scaled, and exited AI and software companies.</p>
          </div>
        </article>
      </div>
      <div class="lead-foot" data-reveal>
        <a class="textlink" href="/team">Meet the full team <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
      </div>
    </div>
  </section>

  <!-- ===================================================== VISION ===================================================== -->
  <section class="section bg-navy" id="vision" aria-labelledby="vision-h">
    <div class="dot-field" aria-hidden="true" style="opacity:.1;"></div>
    <div class="container">
      <div class="statement">
        <span class="eyebrow" data-reveal>Where we&rsquo;re going</span>
        <h2 id="vision-h" class="statement-lead" data-reveal data-delay="1">Tavali&rsquo;s vision is to become the <span class="accent">default operating system</span> for dental care.</h2>
        <p class="statement-body" data-reveal data-delay="2">The single platform a practice runs on — from the first patient interaction through diagnosis, treatment, and reimbursement — extended across the consolidating landscape of groups, DSOs, and franchises.</p>
      </div>
    </div>
  </section>

  <!-- ===================================================== FINAL CTA ===================================================== -->
  <section class="section bg-navy final-cta" id="about-cta" aria-labelledby="final-h">
    <div class="hero-glow" aria-hidden="true" style="left:50%;top:-30%;transform:translateX(-50%);"></div>
    <div class="dot-field" aria-hidden="true" style="opacity:.1;-webkit-mask-image:radial-gradient(ellipse 70% 100% at 50% 0,#000,transparent 70%);mask-image:radial-gradient(ellipse 70% 100% at 50% 0,#000,transparent 70%);"></div>
    <div class="container final-cta-inner">
      <h2 id="final-h" data-reveal>Join us in modernizing dental care.</h2>
      <p class="lead" data-reveal data-delay="1">Book a 30-minute demo and we&rsquo;ll walk your team through Tavali on your workflows.</p>
      <div class="final-cta-row" data-reveal data-delay="2">
        <a class="btn btn--primary btn--lg" href="#">Book a Demo <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        <a class="btn btn--ghost btn--lg" href="/team">Meet the Team</a>
      </div>
    </div>
  </section>

</main>
</BaseLayout>
