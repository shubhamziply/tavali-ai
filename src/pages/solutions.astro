---
/**
 * solutions.astro — migrated from "Solutions.html".
 * Static marketing/content page. Shared chrome (head, header, nav, footer) is
 * provided by BaseLayout; this file holds the page-unique <main> body and its
 * structured data. Generated by scripts/migrate-pages.mjs, then maintained by
 * hand.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/styles-solutions.css';
---
<BaseLayout
  title="Tavali Solutions — Dental Software by Practice Type &amp; Need"
  description="Tavali adapts to how your practice works — single office, group practice, DSO, or franchise — and to the problem costing you the most: claim denials, documentation time, staffing strain, or case acceptance. Explore solutions by organization or by need."
  canonical="https://www.tavali.com/solutions/"
  ogDescription="Explore Tavali two ways: by the kind of organization you run, or by the problem you need to solve first. One connected platform for every practice."
  ogImage="https://www.tavali.com/og-solutions.png"
  ogImageAlt="Tavali solutions — by organization type and by need."
  thumbnailLabel="Solutions"
>
  <Fragment slot="jsonld" set:html={`<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": "https://www.tavali.com/solutions/#faq",
  "url": "https://www.tavali.com/solutions/",
  "inLanguage": "en-US",
  "mainEntity": [
    { "@type": "Question", "name": "What kinds of dental practices does Tavali support?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali supports single-location offices, group practices, dental service organizations (DSOs), and franchises on one platform." } },
    { "@type": "Question", "name": "Can I start with just one problem instead of the whole platform?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Practices can start with a single high-impact solution — such as reducing denials or cutting documentation time — and expand across the platform without switching systems." } },
    { "@type": "Question", "name": "How does Tavali help reduce claim denials?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali scores claims for denial risk before submission and uses grounded, AI-assisted coding that selects accurate codes from authoritative code sets." } },
    { "@type": "Question", "name": "How does Tavali help with staffing shortages?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali automates administrative work and guides staff through tasks in real time, so a smaller or less-specialized team can run the practice effectively." } },
    { "@type": "Question", "name": "Does Tavali work across multiple locations?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Group practices, DSOs, and franchises can standardize and govern workflows centrally while every location runs on one connected data layer." } }
  ]
}
</script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": "https://www.tavali.com/solutions/#breadcrumb",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.tavali.com/" },
    { "@type": "ListItem", "position": 2, "name": "Solutions", "item": "https://www.tavali.com/solutions/" }
  ]
}
</script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "@id": "https://www.tavali.com/solutions/#solutions",
  "name": "Tavali Solutions",
  "description": "Tavali solutions by organization type and by need.",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Single Office", "url": "https://www.tavali.com/solutions/single-office/" },
    { "@type": "ListItem", "position": 2, "name": "Group Practice", "url": "https://www.tavali.com/solutions/group-practice/" },
    { "@type": "ListItem", "position": 3, "name": "DSO", "url": "https://www.tavali.com/solutions/dso/" },
    { "@type": "ListItem", "position": 4, "name": "Franchise", "url": "https://www.tavali.com/solutions/franchise/" },
    { "@type": "ListItem", "position": 5, "name": "Reduce Claim Denials", "url": "https://www.tavali.com/solutions/reduce-denials/" },
    { "@type": "ListItem", "position": 6, "name": "Cut Documentation Time", "url": "https://www.tavali.com/solutions/cut-documentation-time/" },
    { "@type": "ListItem", "position": 7, "name": "Solve Staffing Strain", "url": "https://www.tavali.com/solutions/solve-staffing/" },
    { "@type": "ListItem", "position": 8, "name": "Increase Case Acceptance", "url": "https://www.tavali.com/solutions/increase-case-acceptance/" }
  ]
}
</script>`} />

<main id="main">

  <!-- ===================================================== HERO ===================================================== -->
  <section class="hero hero--solutions" aria-labelledby="page-h">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-bg-dots"></div>
      <canvas class="hero-canvas"></canvas>
      <div class="hero-glow"></div>
    </div>
    <div class="container">
      <div class="hero-grid">
        <div class="hero-copy">
          <span class="eyebrow" data-reveal>Solutions</span>
          <h1 id="page-h" data-reveal data-delay="1">Solutions</h1>
          <p class="hero-def" data-reveal data-delay="1">Tavali adapts to how your practice actually works — whether you run a <span class="accent">single office or a multi-location DSO</span>, and whatever problem is costing you the most today.</p>
          <p class="hero-sub" data-reveal data-delay="2">Explore Tavali two ways: by the kind of organization you run, or by the problem you need to solve first.</p>
          <div class="hero-cta" data-reveal data-delay="3">
            <a class="btn btn--primary btn--hero" href="#solutions-cta">Book a Demo <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a class="btn btn--ghost btn--lg" href="/platform">Explore the Platform</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== TWO PATHS ===================================================== -->
  <section class="section bg-surface" id="explore" aria-labelledby="paths-h">
    <div class="container">
      <div class="section-head" style="max-width:760px;">
        <span class="eyebrow" data-reveal>Two ways in</span>
        <h2 id="paths-h" data-reveal data-delay="1">Find your practice in Tavali.</h2>
        <p class="lead" data-reveal data-delay="2">Every Tavali solution is the same connected platform — applied to a specific kind of practice, or aimed at a specific problem. Start wherever you recognize yourself.</p>
      </div>
      <div class="paths-grid">
        <a class="path-card" href="#by-org" data-reveal>
          <span class="path-ico" data-dots="0000011011110111121111011" data-size="34" aria-hidden="true"></span>
          <span><span class="h3" style="display:block;font-weight:700;font-size:1.2rem;color:var(--navy);letter-spacing:-.02em;">By your organization</span><p>Single office, group, DSO, or franchise — see how Tavali fits your structure.</p></span>
          <span class="path-arrow" aria-hidden="true"><svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        </a>
        <a class="path-card" href="#by-need" data-reveal data-delay="1">
          <span class="path-ico" data-dots="0010000100001000000000200" data-size="34" aria-hidden="true"></span>
          <span><span class="h3" style="display:block;font-weight:700;font-size:1.2rem;color:var(--navy);letter-spacing:-.02em;">By what you need to fix</span><p>Denials, documentation time, staffing, or case acceptance — start with the biggest pain.</p></span>
          <span class="path-arrow" aria-hidden="true"><svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ===================================================== BY ORGANIZATION ===================================================== -->
  <section class="section" id="by-org" aria-labelledby="byorg-h">
    <div class="container">
      <div class="path-head" data-reveal>
        <span class="path-num" aria-hidden="true">01<span class="path-num-dot" data-dots="1000000000001000000000001" data-size="18"></span></span>
        <div class="path-head-text">
          <span class="path-tag">Path 01 · By who you are</span>
          <h2 id="byorg-h">Built for every kind of dental organization.</h2>
          <p class="lead">Tavali supports single-location offices, group practices, dental service organizations, and franchises — all on one platform.</p>
        </div>
      </div>
      <div class="sol-grid sol-grid--org">
        <article class="sol-card" id="s-single-office" data-reveal>
          <span class="sol-ico" data-dots="0010001110010100121001110" data-size="46" aria-hidden="true"></span>
          <h3>Single Office</h3>
          <p class="sol-stmt">Tavali lets a single office run lean by putting AI on the busywork so a small team can do more.</p>
          <ul class="sol-bullets">
            <li><span class="bdot" aria-hidden="true"></span>One platform instead of four-to-seven tools</li>
            <li><span class="bdot" aria-hidden="true"></span>AI agents handle scheduling, billing, and follow-up</li>
            <li><span class="bdot" aria-hidden="true"></span>Less reliance on hard-to-hire staff</li>
          </ul>
          <p class="sol-link"><a class="textlink" href="solutions/single-office">See how Tavali fits a single office <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a></p>
        </article>
        <article class="sol-card" id="s-group" data-reveal data-delay="1">
          <span class="sol-ico" data-dots="0000011011110111121111011" data-size="46" aria-hidden="true"></span>
          <h3>Group Practice</h3>
          <p class="sol-stmt">Tavali standardizes clinical and operational workflows across every location in a group.</p>
          <ul class="sol-bullets">
            <li><span class="bdot" aria-hidden="true"></span>Consistent processes across sites</li>
            <li><span class="bdot" aria-hidden="true"></span>Shared records and cross-location visibility</li>
            <li><span class="bdot" aria-hidden="true"></span>Centralized intelligence and reporting</li>
          </ul>
          <p class="sol-link"><a class="textlink" href="solutions/group-practice">See how Tavali fits a group practice <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a></p>
        </article>
        <article class="sol-card" id="s-dso" data-reveal>
          <span class="sol-ico" data-dots="1010100000012100000010101" data-size="46" aria-hidden="true"></span>
          <h3>DSO</h3>
          <p class="sol-stmt">Tavali gives a dental service organization centralized governance and intelligence that scale across the entire portfolio.</p>
          <ul class="sol-bullets">
            <li><span class="bdot" aria-hidden="true"></span>Govern policy and coding centrally, enforce it everywhere</li>
            <li><span class="bdot" aria-hidden="true"></span>Portfolio-wide analytics and forecasting</li>
            <li><span class="bdot" aria-hidden="true"></span>Scales to many locations on one data layer</li>
          </ul>
          <p class="sol-link"><a class="textlink" href="solutions/dso">See how Tavali fits a DSO <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a></p>
        </article>
        <article class="sol-card" id="s-franchise" data-reveal data-delay="1">
          <span class="sol-ico" data-dots="1010100000102010000010101" data-size="46" aria-hidden="true"></span>
          <h3>Franchise</h3>
          <p class="sol-stmt">Tavali keeps operations consistent and on-brand across every franchise location.</p>
          <ul class="sol-bullets">
            <li><span class="bdot" aria-hidden="true"></span>Standardized workflows and patient experience</li>
            <li><span class="bdot" aria-hidden="true"></span>Local autonomy within central guardrails</li>
            <li><span class="bdot" aria-hidden="true"></span>One system every location runs on</li>
          </ul>
          <p class="sol-link"><a class="textlink" href="solutions/franchise">See how Tavali fits a franchise <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a></p>
        </article>
      </div>
    </div>
  </section>

  <!-- ===================================================== BY NEED ===================================================== -->
  <div class="path-divider" aria-hidden="true">
    <span class="path-divider-line"></span>
    <span class="path-divider-or">or</span>
    <span class="path-divider-line"></span>
  </div>
  <section class="section bg-surface" id="by-need" aria-labelledby="byneed-h">
    <div class="container">
      <div class="path-head path-head--need" data-reveal>
        <span class="path-num" aria-hidden="true">02<span class="path-num-dot" data-dots="1000000000001000000000001" data-size="18"></span></span>
        <div class="path-head-text">
          <span class="path-tag">Path 02 · By what you need to fix</span>
          <h2 id="byneed-h">Whatever's costing you the most — start there.</h2>
          <p class="lead">Tavali lets you start with whatever problem is hurting your practice most today, then expand across the rest on the same connected platform.</p>
        </div>
      </div>
      <div class="sol-grid sol-grid--need">
        <article class="sol-card" id="s-reduce-denials" data-reveal>
          <span class="sol-ico" data-dots="0010000100001000000000200" data-size="46" aria-hidden="true"></span>
          <span class="sol-kicker">Reduce claim denials</span>
          <h3>Stop losing revenue to denied claims.</h3>
          <p class="sol-stmt">Tavali scores claims for denial risk before submission and uses grounded, AI-assisted coding to bill accurately.</p>
          <ul class="sol-bullets">
            <li><span class="bdot" aria-hidden="true"></span>Pre-submission denial-risk scoring</li>
            <li><span class="bdot" aria-hidden="true"></span>Accurate coding from authoritative code sets</li>
            <li><span class="bdot" aria-hidden="true"></span>Faster, cleaner revenue cycle</li>
          </ul>
          <p class="sol-link"><a class="textlink" href="solutions/reduce-denials">Learn more about reducing denials <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a></p>
        </article>
        <article class="sol-card" id="s-cut-docs" data-reveal data-delay="1">
          <span class="sol-ico" data-dots="0111010001102011001101110" data-size="46" aria-hidden="true"></span>
          <span class="sol-kicker">Cut documentation time</span>
          <h3>Give clinicians their time back.</h3>
          <p class="sol-stmt">Tavali's ambient AI scribe drafts clinical notes from the visit so providers spend less time documenting and more time with patients.</p>
          <ul class="sol-bullets">
            <li><span class="bdot" aria-hidden="true"></span>Ambient AI scribe</li>
            <li><span class="bdot" aria-hidden="true"></span>Structured notes that flow into the record</li>
            <li><span class="bdot" aria-hidden="true"></span>Less after-hours charting</li>
          </ul>
          <p class="sol-link"><a class="textlink" href="solutions/cut-documentation-time">Learn more about cutting documentation time <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a></p>
        </article>
        <article class="sol-card" id="s-staffing" data-reveal>
          <span class="sol-ico" data-dots="1000101010001000101010001" data-size="46" aria-hidden="true"></span>
          <span class="sol-kicker">Solve staffing strain</span>
          <h3>Run your practice with fewer, less-stretched hands.</h3>
          <p class="sol-stmt">Tavali automates administrative work and guides staff through tasks in real time, so a smaller or less-specialized team can run the practice effectively.</p>
          <ul class="sol-bullets">
            <li><span class="bdot" aria-hidden="true"></span>AI agents handle the admin load</li>
            <li><span class="bdot" aria-hidden="true"></span>On-the-job guidance ramps new hires fast</li>
            <li><span class="bdot" aria-hidden="true"></span>Less exposure to turnover and vacancies</li>
          </ul>
          <p class="sol-link"><a class="textlink" href="solutions/solve-staffing">Learn more about solving staffing strain <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a></p>
        </article>
        <article class="sol-card" id="s-case-acceptance" data-reveal data-delay="1">
          <span class="sol-ico" data-dots="0000200012001120111211112" data-size="46" aria-hidden="true"></span>
          <span class="sol-kicker">Increase case acceptance</span>
          <h3>Help more patients say yes to needed care.</h3>
          <p class="sol-stmt">Tavali improves how treatment is explained and presented, so more recommended care is understood and accepted.</p>
          <ul class="sol-bullets">
            <li><span class="bdot" aria-hidden="true"></span>Clearer, AI-assisted treatment explanation</li>
            <li><span class="bdot" aria-hidden="true"></span>Better-informed patients</li>
            <li><span class="bdot" aria-hidden="true"></span>More accepted, delivered care</li>
          </ul>
          <p class="sol-link"><a class="textlink" href="solutions/increase-case-acceptance">Learn more about increasing case acceptance <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a></p>
        </article>
      </div>
    </div>
  </section>

  <!-- ===================================================== CONNECTIVE INSIGHT ===================================================== -->
  <section class="section bg-navy connect" aria-labelledby="connect-h">
    <div class="dot-field" aria-hidden="true" style="opacity:.1;"></div>
    <div class="container">
      <div class="connect-inner">
        <span class="eyebrow" data-reveal>One platform</span>
        <h2 id="connect-h" data-reveal data-delay="1">Different problems. Different practices. <span class="hl">One platform.</span></h2>
        <p class="lead" data-reveal data-delay="2">Every Tavali solution is the same AI-native platform — not separate products bolted together — focused on what matters most to your practice. Solve one problem first, then expand across the rest without switching systems.</p>
      </div>
    </div>
  </section>

  <!-- ===================================================== OUTCOMES ===================================================== -->
  <section class="section" id="outcomes" aria-labelledby="outcomes-h">
    <div class="container">
      <div class="section-head center" data-reveal>
        <span class="eyebrow">Outcomes</span>
        <h2 id="outcomes-h">Built to move the numbers that matter.</h2>
        <p class="lead">Tavali is designed to deliver measurable impact across revenue, clinical time, and case acceptance.</p>
      </div>
      <div class="metric-strip" data-reveal>
        <div class="metric"><div class="m-num"><span class="dir">↓</span>45%</div><div class="m-lbl">Claim denials</div></div>
        <div class="metric"><div class="m-num"><span class="dir">↓</span>60%</div><div class="m-lbl">Documentation time</div></div>
        <div class="metric"><div class="m-num">120<span style="font-size:1.2rem;">+</span></div><div class="m-lbl">Admin hours saved / month</div></div>
        <div class="metric"><div class="m-num"><span class="dir">↑</span>25%</div><div class="m-lbl">Case acceptance</div></div>
      </div>
      <p class="outcomes-note" data-reveal>Target outcomes / design objectives.</p>
    </div>
  </section>

  <!-- ===================================================== FAQ ===================================================== -->
  <section class="section bg-surface" id="faq" aria-labelledby="faq-h">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow" data-reveal>Solutions FAQ</span>
        <h2 id="faq-h" data-reveal data-delay="1">Which dental practices is Tavali for?</h2>
        <p class="lead" data-reveal data-delay="2">Straight answers about who Tavali fits, where to start, and how it scales.</p>
      </div>
      <div class="faq-wrap" data-reveal>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><span>What kinds of dental practices does Tavali support?</span><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Tavali supports single-location offices, group practices, dental service organizations (DSOs), and franchises on one platform.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><span>Can I start with just one problem instead of the whole platform?</span><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Yes. Practices can start with a single high-impact solution — such as reducing denials or cutting documentation time — and expand across the platform without switching systems.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><span>How does Tavali help reduce claim denials?</span><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Tavali scores claims for denial risk before submission and uses grounded, AI-assisted coding that selects accurate codes from authoritative code sets.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><span>How does Tavali help with staffing shortages?</span><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Tavali automates administrative work and guides staff through tasks in real time, so a smaller or less-specialized team can run the practice effectively.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><span>Does Tavali work across multiple locations?</span><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Yes. Group practices, DSOs, and franchises can standardize and govern workflows centrally while every location runs on one connected data layer.</p></div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== FINAL CTA ===================================================== -->
  <section class="section bg-navy final-cta" id="solutions-cta" aria-labelledby="final-h">
    <div class="hero-glow" aria-hidden="true" style="left:50%;top:-30%;transform:translateX(-50%);"></div>
    <div class="dot-field" aria-hidden="true" style="opacity:.1;-webkit-mask-image:radial-gradient(ellipse 70% 100% at 50% 0,#000,transparent 70%);mask-image:radial-gradient(ellipse 70% 100% at 50% 0,#000,transparent 70%);"></div>
    <div class="container final-cta-inner">
      <h2 id="final-h" data-reveal>Find your practice in Tavali.</h2>
      <p class="lead" data-reveal data-delay="1">Book a 30-minute demo and we'll show you Tavali on your kind of practice, aimed at your biggest problem.</p>
      <div class="final-cta-row" data-reveal data-delay="2">
        <a class="btn btn--primary btn--lg" href="#">Book a Demo <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        <a class="btn btn--ghost btn--lg" href="/platform">Explore the Platform</a>
      </div>
    </div>
  </section>

</main>
</BaseLayout>
