---
/**
 * index.astro — migrated from "Tavali Home.html".
 * Static marketing/content page. Shared chrome (head, header, nav, footer) is
 * provided by BaseLayout; this file holds the page-unique <main> body and its
 * structured data. Generated by scripts/migrate-pages.mjs, then maintained by
 * hand.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Tavali — The AI-Native Operating System for Dental Practices"
  description="Tavali is an AI-native operating system for dental practices that unifies clinical care, front-office operations, records, billing, and autonomous AI agents into one platform — so practices capture more revenue, save time, and run on fewer hands."
  canonical="https://www.tavali.com/"
  ogDescription="One platform for clinical intelligence, front office, records, billing, and autonomous AI agents — built for single offices, groups, DSOs, and franchises."
  ogImage="https://www.tavali.com/og-image.png"
  ogImageAlt="Tavali — the AI-native operating system for dental practices."
  thumbnailLabel="Home"
  ctaGhostLabel="Explore the Platform"
  ctaGhostHref="/platform"
>
  <Fragment slot="jsonld" set:html={`<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://www.tavali.com/#organization",
  "name": "Tavali, Inc.",
  "url": "https://www.tavali.com/",
  "logo": {
    "@type": "ImageObject",
    "url": "https://www.tavali.com/logo.png",
    "width": 2015,
    "height": 720
  },
  "slogan": "The AI-native operating system for dental practices.",
  "description": "Tavali is an AI-native operating system for dental practices that unifies clinical care, operations, and revenue into a single, AI-driven platform.",
  "foundingDate": "2025",
  "knowsAbout": [
    "AI-native dental operating system",
    "Dental practice management",
    "Clinical AI",
    "Dental claim denial prevention",
    "Dental revenue cycle management"
  ],
  "sameAs": ["https://www.linkedin.com/company/tavali"],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "Sales",
    "email": "hello@tavali.com",
    "areaServed": "US",
    "availableLanguage": "English"
  }
}
</script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://www.tavali.com/#website",
  "url": "https://www.tavali.com/",
  "name": "Tavali",
  "description": "The AI-native operating system for dental practices.",
  "publisher": { "@id": "https://www.tavali.com/#organization" },
  "inLanguage": "en-US"
}
</script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "@id": "https://www.tavali.com/#software",
  "name": "Tavali",
  "url": "https://www.tavali.com/",
  "image": "https://www.tavali.com/og-image.png",
  "applicationCategory": "BusinessApplication",
  "applicationSubCategory": "Dental Practice Management & Clinical AI",
  "operatingSystem": "Web",
  "description": "An AI-native operating system for dental practices that unifies clinical intelligence, front-office operations, practice management, billing, and autonomous AI agents in one platform.",
  "featureList": [
    "Clinical AI — ambient scribe, diagnostic support, charting",
    "Front Office — scheduling, communications, intake",
    "PMS / EHR — system of record for patients, charts, billing",
    "Intelligence — predictive analytics and denial-prevention scoring",
    "Agents — autonomous AI agents for scheduling, billing, follow-up",
    "Diagnostics — imaging intelligence across X-ray, CBCT, intraoral scans"
  ],
  "offers": {
    "@type": "Offer",
    "category": "Subscription",
    "priceCurrency": "USD",
    "availability": "https://schema.org/PreOrder"
  },
  "publisher": { "@id": "https://www.tavali.com/#organization" },
  "provider": { "@id": "https://www.tavali.com/#organization" }
}
</script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": "https://www.tavali.com/#faq",
  "url": "https://www.tavali.com/",
  "inLanguage": "en-US",
  "isPartOf": { "@id": "https://www.tavali.com/#website" },
  "mainEntity": [
    { "@type": "Question", "name": "What is Tavali?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali is an AI-native operating system for dental practices that unifies clinical intelligence, front-office operations, practice management, billing, and autonomous AI agents in one platform." } },
    { "@type": "Question", "name": "What does \"AI-native\" mean?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali was built around AI from the ground up — a conversational assistant and specialized agents that perform work across the practice — rather than adding AI features onto legacy software." } },
    { "@type": "Question", "name": "Who is Tavali for?", "acceptedAnswer": { "@type": "Answer", "text": "Single-location offices, group practices, dental service organizations (DSOs), and franchises." } },
    { "@type": "Question", "name": "How does Tavali reduce claim denials?", "acceptedAnswer": { "@type": "Answer", "text": "It scores claims for denial risk before submission and uses grounded, AI-assisted coding that selects accurate codes from authoritative code sets." } },
    { "@type": "Question", "name": "Does Tavali keep clinicians in control?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Clinical decisions are always provider-approved through a trust-tier governance model; agents act within defined limits." } },
    { "@type": "Question", "name": "How does Tavali help with staffing shortages?", "acceptedAnswer": { "@type": "Answer", "text": "It automates administrative work and guides staff through tasks in real time, so a smaller or less-specialized team can run the practice effectively." } },
    { "@type": "Question", "name": "What makes Tavali different from point solutions?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali connects the entire workflow on one data layer — from a clinical finding through to a payer-ready claim — which separate tools cannot do." } }
  ]
}
</script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": "https://www.tavali.com/#breadcrumb",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.tavali.com/" }
  ]
}
</script>`} />

<main id="main">

  <!-- ===================================================== HERO ===================================================== -->
  <section class="hero" aria-labelledby="hero-h">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-bg-dots"></div>
      <canvas class="hero-canvas"></canvas>
      <div class="hero-glow"></div>
    </div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <h1 id="hero-h" data-reveal data-delay="1">The AI-native operating system for <span class="hl">dental practices</span></h1>
        <p class="hero-sub" data-reveal data-delay="2">Tavali brings clinical intelligence, front office, records, billing, and autonomous AI agents into one platform — so your practice captures more revenue, saves time, and runs on fewer, less-stretched hands.</p>
        <div class="hero-cta" data-reveal data-delay="3">
          <a class="btn btn--primary btn--hero" href="#footer-cta">Book a Demo <svg class="btn-arrow" width="18" height="18" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
          <a class="btn btn--ghost btn--lg" href="/platform">Explore the Platform</a>
        </div>
      </div>

      <!-- Abstract product-UI suggestion (stylized, not a real screenshot) -->
      <div class="hero-visual" data-reveal data-delay="2" aria-hidden="true">
        <div class="hero-chip c1"><span class="num">↓60%</span> documentation time</div>
        <div class="hero-card">
          <div class="hc-head">
            <span class="hc-avatar" data-dots="2000200000002000000000000" data-size="22"></span>
            <span>
              <span class="hc-title">TAVI</span>
              <span class="hc-sub" style="display:block;">AI assistant · provider-governed</span>
            </span>
            <span class="hc-live"><i></i> Working</span>
          </div>
          <div class="hc-bubble">Finding logged on <strong>#19-MO</strong>. Drafting the note, treatment plan, and a coverage-aware estimate now.</div>
          <div class="hc-bubble">Claim checked for denial risk: <strong style="color:#2E7D32;">low</strong>. Codes grounded to authoritative sets — ready for your approval.</div>
          <div class="hc-flow">
            <span class="step">finding</span><span class="arr">→</span>
            <span class="step">chart</span><span class="arr">→</span>
            <span class="step">plan</span><span class="arr">→</span>
            <span class="step">estimate</span><span class="arr">→</span>
            <span class="step lit">claim</span>
          </div>
        </div>
        <div class="hero-chip c2"><span class="chip-pip" aria-hidden="true"><i></i><i></i><i></i></span> Proprietary, fully-integrated AI architecture</div>
      </div>
    </div>
  </section>

  <!-- ===================================================== TRUST STRIP ===================================================== -->
  <section class="trust" aria-labelledby="trust-h">
    <div class="container trust-inner">
      <p class="trust-line" id="trust-h" data-reveal>Tavali is an <span class="accent">AI-native operating system</span> for dental practices.</p>
      <ul class="proof-row">
        <li class="proof-chip" data-reveal><span class="proof-dot" aria-hidden="true"></span>Built for single offices, groups, DSOs &amp; franchises</li>
        <li class="proof-chip" data-reveal data-delay="1"><span class="proof-dot" aria-hidden="true"></span>AI-native — built around AI, not bolted on</li>
        <li class="proof-chip" data-reveal data-delay="2"><span class="proof-dot" aria-hidden="true"></span>One platform replaces 4–7 tools</li>
        <li class="proof-chip" data-reveal data-delay="3"><span class="proof-dot" aria-hidden="true"></span>Clinicians always in control</li>
      </ul>
    </div>
  </section>

  <!-- ===================================================== PROBLEM ===================================================== -->
  <section class="section bg-surface" id="problem" aria-labelledby="problem-h">
    <div class="container problem-grid">
      <div>
        <span class="eyebrow" data-reveal>The problem</span>
        <h2 id="problem-h" style="font-size:clamp(1.9rem,3.8vw,2.9rem);margin-top:.85rem;" data-reveal data-delay="1">Dental practices run on fragmented, legacy software.</h2>
        <p class="lead" style="margin-top:1.1rem;" data-reveal data-delay="2">The typical practice juggles four to seven disconnected tools while facing the industry's hardest problems — staffing shortages (the #1 challenge for dentists), rising claim denials, and hours lost to documentation. Tavali replaces the patchwork with one intelligent system.</p>
        <div class="pain-list">
          <div class="pain" data-reveal data-delay="2"><span class="pico" data-dots="0000011011110111121111011" data-size="28"></span><div><h4>Staffing strain</h4><p>The #1 challenge for dentists — fewer hands stretched across more work.</p></div></div>
          <div class="pain" data-reveal data-delay="3"><span class="pico" data-dots="0010000100001000000000200" data-size="28"></span><div><h4>Rising claim denials</h4><p>Revenue lost to errors caught only after submission.</p></div></div>
          <div class="pain" data-reveal data-delay="4"><span class="pico" data-dots="0111010001102011001101110" data-size="28"></span><div><h4>Hours lost to documentation</h4><p>Clinical time drained by charting and notes.</p></div></div>
        </div>
      </div>
      <div class="fragmented" data-reveal data-delay="2">
        <div class="dot-field" style="opacity:.1;"></div>
        <p class="lbl">Today: a disconnected stack</p>
        <div class="scatter">
          <span class="tool x">Scheduling</span><span class="tool x">Imaging</span><span class="tool x">Charting</span>
          <span class="tool x">Billing</span><span class="tool x">Comms</span><span class="tool x">Analytics</span><span class="tool x">Claims</span>
        </div>
        <p class="frag-arrow">↓ unified into</p>
        <div class="unified-pill"><span class="logo-lockup"><svg width="20" height="20" viewBox="0 0 52 52" aria-hidden="true"><circle cx="6" cy="6" r="4" fill="#fff"/><circle cx="46" cy="6" r="4" fill="#fff"/><circle cx="26" cy="26" r="4" fill="#fff"/><circle cx="26" cy="6" r="4" fill="#fff" fill-opacity=".4"/><circle cx="46" cy="26" r="4" fill="#fff" fill-opacity=".4"/><circle cx="6" cy="26" r="4" fill="#fff" fill-opacity=".4"/></svg></span> one intelligent system</div>
      </div>
    </div>
  </section>

  <!-- ===================================================== HORIZONS ===================================================== -->
  <section class="section" id="horizons" aria-labelledby="horizons-h">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow" data-reveal>The platform</span>
        <h2 id="horizons-h" data-reveal data-delay="1">One platform. Six layers of intelligence.</h2>
        <p class="lead" data-reveal data-delay="2">Tavali unifies the work of a modern dental practice into six connected horizons — every layer sharing one data foundation.</p>
      </div>
      <div class="horizons">
        <article class="horizon" data-reveal><span class="h-num">01</span><span class="h-ico" data-dots="0010000100112110010000100" data-size="52"></span><h3>Clinical AI</h3><p>Ambient AI scribe, diagnostic support, and charting that give clinicians their time back.</p></article>
        <article class="horizon" data-reveal data-delay="1"><span class="h-num">02</span><span class="h-ico" data-dots="1111110201100011000111111" data-size="52"></span><h3>Front Office</h3><p>Unified scheduling, communications, and intake on one screen.</p></article>
        <article class="horizon" data-reveal data-delay="2"><span class="h-num">03</span><span class="h-ico" data-dots="1111000000112100000011110" data-size="52"></span><h3>PMS / EHR</h3><p>The complete system of record for patients, charts, and billing.</p></article>
        <article class="horizon" data-reveal><span class="h-num">04</span><span class="h-ico" data-dots="0000200012001120111211112" data-size="52"></span><h3>Intelligence</h3><p>Predictive analytics, revenue forecasting, and denial-prevention scoring.</p></article>
        <article class="horizon" data-reveal data-delay="1"><span class="h-num">05</span><span class="h-ico" data-dots="1000100000002000000010001" data-size="52"></span><h3>Agents</h3><p>Autonomous AI agents that do the work — scheduling, billing, follow-up — under your control.</p></article>
        <article class="horizon" data-reveal data-delay="2"><span class="h-num">06</span><span class="h-ico" data-dots="0111011111112110101001010" data-size="52"></span><h3>Diagnostics</h3><p>Imaging intelligence across X-ray, CBCT, and intraoral scans, unified per tooth.</p></article>
      </div>
    </div>
  </section>

  <!-- ===================================================== INTEGRATION MOAT ===================================================== -->
  <section class="section bg-navy moat" id="moat" aria-labelledby="moat-h">
    <div class="dot-field" aria-hidden="true" style="opacity:.1;"></div>
    <div class="moat-aura" aria-hidden="true"></div>
    <div class="container">
      <div class="section-head center" style="max-width:820px;">
        <span class="eyebrow" data-reveal>The integration moat</span>
        <h2 id="moat-h" style="color:#fff;" data-reveal data-delay="1">From finding to paid claim — one intelligent flow.</h2>
        <p class="lead" data-reveal data-delay="2">Point tools stop at one step. Tavali carries a single clinical finding all the way through — to documentation, treatment plan, a coverage-aware estimate, and a payer-ready claim — as one governed, end-to-end flow. That connected workflow is what no collection of separate tools can match.</p>
      </div>

      <div class="moat-diagram" data-reveal data-delay="2">
        <p class="moat-carry"><span class="moat-carry-dot" data-dots="0111010001102011000101110" data-size="16"></span> One finding, carried the whole way</p>
        <div class="moat-track">
        <div class="moat-rail" aria-hidden="true">
          <span class="rail-pulse"></span>
          <span class="rail-pulse d2"></span>
          <span class="rail-pulse d3"></span>
        </div>
        <ol class="moat-steps">
          <li class="mstep">
            <span class="mstep-node"><span class="mstep-ico dots--on-dark" data-dots="0111010001102011000101110" data-size="34"></span></span>
            <span class="mstep-body">
              <span class="mstep-no">STEP 01</span>
              <h4>Finding</h4>
              <span class="mstep-chip">#19-MO</span>
              <p>A clinical finding is captured at the chair.</p>
            </span>
          </li>
          <li class="mstep">
            <span class="mstep-node"><span class="mstep-ico dots--on-dark" data-dots="1111110101112111010111111" data-size="34"></span></span>
            <span class="mstep-body">
              <span class="mstep-no">STEP 02</span>
              <h4>Chart</h4>
              <span class="mstep-chip">note drafted</span>
              <p>Documented and charted automatically.</p>
            </span>
          </li>
          <li class="mstep">
            <span class="mstep-node"><span class="mstep-ico dots--on-dark" data-dots="1111000000111000000011112" data-size="34"></span></span>
            <span class="mstep-body">
              <span class="mstep-no">STEP 03</span>
              <h4>Plan</h4>
              <span class="mstep-chip">treatment plan</span>
              <p>Turned into a clear treatment plan.</p>
            </span>
          </li>
          <li class="mstep">
            <span class="mstep-node"><span class="mstep-ico dots--on-dark" data-dots="0111010000012100000101110" data-size="34"></span></span>
            <span class="mstep-body">
              <span class="mstep-no">STEP 04</span>
              <h4>Estimate</h4>
              <span class="mstep-chip">est. $420 · coverage</span>
              <p>Priced with a coverage-aware estimate.</p>
            </span>
          </li>
          <li class="mstep mstep--final">
            <span class="mstep-node"><span class="mstep-ico dots--on-accent" data-dots="1111110001112111000111111" data-size="34"></span></span>
            <span class="mstep-body">
              <span class="mstep-no">STEP 05</span>
              <h4>Payer-ready claim</h4>
              <span class="mstep-chip">claim ready <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true" style="vertical-align:-1px;"><path d="M2.5 6.2l2.3 2.3L9.8 3.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <p>Submitted as a clean, denial-checked claim.</p>
            </span>
          </li>
        </ol>
        </div>
        <div class="moat-foot">
          <span class="governed-tag"><svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 1l5 2v4c0 3.5-2.2 6.3-5 7-2.8-.7-5-3.5-5-7V3l5-2z" fill="none" stroke="#5B8AC0" stroke-width="1.4" stroke-linejoin="round"/><path d="M5.5 8l1.8 1.8L11 6" fill="none" stroke="#5B8AC0" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg> One governed flow on a single data layer</span>
          <span class="moat-contrast">Point tools stop at one step.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== OUTCOMES ===================================================== -->
  <section class="section bg-surface" id="outcomes" aria-labelledby="outcomes-h">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow" data-reveal>Outcomes</span>
        <h2 id="outcomes-h" data-reveal data-delay="1">Built to move the numbers that matter.</h2>
        <p class="lead" data-reveal data-delay="2">Tavali is designed to deliver measurable impact across clinical time, revenue cycle, and case acceptance.</p>
      </div>
      <div class="stat-grid">
        <div class="stat" data-reveal><div class="s-num"><span class="dir">↓</span>60%</div><div class="s-lbl">Documentation time</div><div class="s-desc">Hours of charting returned to clinicians.</div></div>
        <div class="stat" data-reveal data-delay="1"><div class="s-num"><span class="dir">↓</span>45%</div><div class="s-lbl">Claim denials</div><div class="s-desc">Errors caught before submission.</div></div>
        <div class="stat" data-reveal data-delay="2"><div class="s-num">120<span style="font-size:1.4rem;">+</span></div><div class="s-lbl">Hours saved / month</div><div class="s-desc">Administrative work automated away.</div></div>
        <div class="stat" data-reveal><div class="s-num"><span class="dir">↑</span>25%</div><div class="s-lbl">Case acceptance</div><div class="s-desc">Clearer plans patients say yes to.</div></div>
        <div class="stat" data-reveal data-delay="1"><div class="s-num">35%</div><div class="s-lbl">Faster revenue cycle</div><div class="s-desc">From finding to paid, with less friction.</div></div>
        <div class="stat" data-reveal data-delay="2"><div class="s-num green">+$30K</div><div class="s-lbl">Per month</div><div class="s-desc">Captured revenue per location.</div></div>
      </div>
      <p class="outcomes-note" data-reveal>Target outcomes / design objectives.</p>
    </div>
  </section>

  <!-- ===================================================== WHO IT'S FOR ===================================================== -->
  <section class="section" id="audience" aria-labelledby="audience-h">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow" data-reveal>Who it's for</span>
        <h2 id="audience-h" data-reveal data-delay="1">One platform for every kind of practice.</h2>
        <p class="lead" data-reveal data-delay="2">From a solo operatory to a multi-state organization, Tavali adapts to how your practice runs.</p>
      </div>
      <div class="audience-grid">
        <article class="aud" data-reveal><span class="a-ico" data-dots="0010001110010100121001110" data-size="48"></span><h3>Single Office</h3><p>Enterprise-grade AI for an independent practice — without an IT team.</p></article>
        <article class="aud" data-reveal data-delay="1"><span class="a-ico" data-dots="0000011011110111121111011" data-size="48"></span><h3>Group Practice</h3><p>Consistent workflows and shared intelligence across every location.</p></article>
        <article class="aud" data-reveal data-delay="2"><span class="a-ico" data-dots="1010100000012100000010101" data-size="48"></span><h3>DSO</h3><p>Standardized operations and revenue visibility at organizational scale.</p></article>
        <article class="aud" data-reveal data-delay="3"><span class="a-ico" data-dots="1010100000102010000010101" data-size="48"></span><h3>Franchise</h3><p>A repeatable, brand-consistent operating model for every unit.</p></article>
      </div>
    </div>
  </section>

  <!-- ===================================================== WHY NOW ===================================================== -->
  <section class="section bg-navy whynow" aria-labelledby="whynow-h">
    <div class="dot-field" aria-hidden="true" style="opacity:.08;"></div>
    <div class="container whynow-grid">
      <div>
        <span class="eyebrow" data-reveal>Why now</span>
        <h2 id="whynow-h" data-reveal data-delay="1">AI has arrived in dentistry. <span class="hl">Tavali makes it operational.</span></h2>
        <p class="lead" style="margin-top:1.1rem;" data-reveal data-delay="2">A quarter to a third of practices have already adopted AI, and the FDA has cleared AI for dental imaging. Tavali turns scattered AI point-tools into one governed system built for how dental organizations actually run.</p>
      </div>
      <div class="whynow-stats" data-reveal data-delay="2">
        <div class="wn-stat"><div class="n">25–33%</div><div class="l">of practices have already adopted AI</div></div>
        <div class="wn-stat"><div class="n">FDA-cleared</div><div class="l">AI for dental imaging</div></div>
        <div class="wn-stat"><div class="n">1 system</div><div class="l">replacing scattered point-tools</div></div>
        <div class="wn-stat"><div class="n">Governed</div><div class="l">built for how practices run</div></div>
      </div>
    </div>
  </section>

  <!-- ===================================================== FAQ ===================================================== -->
  <section class="section bg-surface" id="faq" aria-labelledby="faq-h">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow" data-reveal>FAQ</span>
        <h2 id="faq-h" data-reveal data-delay="1">What is an AI-native dental operating system?</h2>
        <p class="lead" data-reveal data-delay="2">Straight answers to how Tavali works, who it's for, and what makes it different.</p>
      </div>
      <div class="faq-wrap" data-reveal>
        <div class="faq-item">
