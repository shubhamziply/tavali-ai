---
/**
 * platform.astro — migrated from "Platform.html".
 * Static marketing/content page. Shared chrome (head, header, nav, footer) is
 * provided by BaseLayout; this file holds the page-unique <main> body and its
 * structured data. Generated by scripts/migrate-pages.mjs, then maintained by
 * hand.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/styles-platform.css';
---
<BaseLayout
  title="Tavali Platform — The AI-Native Dental Operating System"
  description="The Tavali platform unifies clinical care, front office, records, billing, intelligence, and autonomous AI agents on one connected data layer — six horizons, one shared data layer, one assistant (TAVI), always under your control."
  canonical="https://www.tavali.com/platform/"
  ogDescription="Six layers of intelligence. One shared data layer. One assistant — TAVI — orchestrating it all, always under your control."
  ogImage="https://www.tavali.com/og-platform.png"
  ogImageAlt="The Tavali platform — six horizons on one shared data layer."
  thumbnailLabel="Platform"
>
  <Fragment slot="jsonld" set:html={`<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "@id": "https://www.tavali.com/platform/#software",
  "name": "Tavali Platform",
  "url": "https://www.tavali.com/platform/",
  "image": "https://www.tavali.com/og-platform.png",
  "applicationCategory": "BusinessApplication",
  "applicationSubCategory": "Dental Practice Management & Clinical AI",
  "operatingSystem": "Web",
  "description": "The Tavali platform is an AI-native operating system for dental practices that unifies clinical care, front-office operations, records, billing, intelligence, and autonomous agents on a single connected data layer.",
  "featureList": [
    "Clinical AI — AI-assisted documentation, diagnostic support, and charting at the point of care",
    "Front Office — unified scheduling, patient communications, and intake on a single screen",
    "PMS / EHR — the complete system of record for patients, charts, and billing",
    "Intelligence — predictive analytics, revenue forecasting, and denial-prevention scoring",
    "Agents — autonomous AI workers that carry out multi-step tasks under provider control",
    "Diagnostics — imaging intelligence across X-ray, CBCT, and intraoral scans, unified per tooth"
  ],
  "offers": {
    "@type": "Offer",
    "category": "Subscription",
    "priceCurrency": "USD",
    "availability": "https://schema.org/PreOrder"
  },
  "publisher": { "@type": "Organization", "name": "Tavali, Inc.", "@id": "https://www.tavali.com/#organization" }
}
</script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": "https://www.tavali.com/platform/#faq",
  "url": "https://www.tavali.com/platform/",
  "inLanguage": "en-US",
  "mainEntity": [
    { "@type": "Question", "name": "What is the Tavali platform?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali is an AI-native operating system for dental practices that unifies clinical care, front office, records, billing, intelligence, and autonomous agents on one connected data layer." } },
    { "@type": "Question", "name": "What are the six horizons?", "acceptedAnswer": { "@type": "Answer", "text": "Clinical AI, Front Office, PMS/EHR, Intelligence, Agents, and Diagnostics — six layers that share one data layer and one agent fabric." } },
    { "@type": "Question", "name": "What is TAVI?", "acceptedAnswer": { "@type": "Answer", "text": "TAVI is Tavali's conversational assistant that orchestrates specialized AI agents across the platform on the user's behalf." } },
    { "@type": "Question", "name": "Does Tavali replace my existing practice-management system?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali is a complete platform with its own PMS/EHR layer, designed to be the single system a practice runs on rather than another add-on." } },
    { "@type": "Question", "name": "How does Tavali keep clinical decisions safe?", "acceptedAnswer": { "@type": "Answer", "text": "A trust-tier governance model keeps clinical actions provider-approved through a non-overridable safeguard, while routine tasks can be automated." } },
    { "@type": "Question", "name": "Can Tavali scale to multiple locations?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The platform is built for single offices, group practices, DSOs, and franchises, with centralized governance across locations." } }
  ]
}
</script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": "https://www.tavali.com/platform/#breadcrumb",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.tavali.com/" },
    { "@type": "ListItem", "position": 2, "name": "Platform", "item": "https://www.tavali.com/platform/" }
  ]
}
</script>`} />

<main id="main">

  <!-- ===================================================== HERO ===================================================== -->
  <section class="hero hero--platform" aria-labelledby="page-h">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-bg-dots"></div>
      <canvas class="hero-canvas"></canvas>
      <div class="hero-glow"></div>
    </div>
    <div class="container">
      <div class="hero-grid">
        <div class="hero-copy">
          <span class="eyebrow" data-reveal>The platform</span>
          <h1 id="page-h" data-reveal data-delay="1">The Tavali Platform</h1>
          <p class="hero-def" data-reveal data-delay="1">The Tavali platform is an <span class="accent">AI-native operating system for dental practices</span> that unifies clinical care, front-office operations, records, billing, intelligence, and autonomous agents on a single connected data layer.</p>
          <p class="hero-sub" data-reveal data-delay="2">Six layers of intelligence. One shared data layer. One assistant — TAVI — orchestrating it all, always under your control.</p>
          <div class="hero-cta" data-reveal data-delay="3">
            <a class="btn btn--primary btn--hero" href="#platform-cta">Book a Demo <svg class="btn-arrow" width="18" height="18" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a class="btn btn--ghost btn--lg" href="/#outcomes">See Pricing</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== ARCHITECTURE (the differentiator) ===================================================== -->
  <section class="section" id="architecture" aria-labelledby="arch-h">
    <div class="container">
      <div class="section-head" style="max-width:820px;">
        <span class="eyebrow" data-reveal>The architecture</span>
        <h2 id="arch-h" data-reveal data-delay="1">One platform, not six tools bolted together.</h2>
        <p class="lead" data-reveal data-delay="2">The Tavali platform runs all six horizons on one shared data layer, coordinated by a single agent fabric and orchestrated by TAVI — under a governance model that keeps clinical decisions with the provider.</p>
      </div>
      <div class="arch-grid">
        <!-- Diagram: six horizons → TAVI agent fabric → one shared data layer -->
        <div class="arch-diagram" data-reveal aria-label="Diagram: six horizons sit on one shared data layer, woven together by the TAVI agent fabric.">
          <div class="dot-field" aria-hidden="true"></div>
          <p class="arch-cap"><span class="tavi-pip" aria-hidden="true"><i></i><i></i><i></i></span> TAVI orchestrates</p>
          <div class="arch-horizons" aria-hidden="true">
            <div class="arch-hz"><span class="dots--on-dark" data-dots="0010000100112110010000100" data-size="26"></span><small>Clinical AI</small></div>
            <div class="arch-hz"><span class="dots--on-dark" data-dots="1111110201100011000111111" data-size="26"></span><small>Front Office</small></div>
            <div class="arch-hz"><span class="dots--on-dark" data-dots="1111000000112100000011110" data-size="26"></span><small>PMS / EHR</small></div>
            <div class="arch-hz"><span class="dots--on-dark" data-dots="0000200012001120111211112" data-size="26"></span><small>Intelligence</small></div>
            <div class="arch-hz"><span class="dots--on-dark" data-dots="1000100000002000000010001" data-size="26"></span><small>Agents</small></div>
            <div class="arch-hz"><span class="dots--on-dark" data-dots="0111011111112110101001010" data-size="26"></span><small>Diagnostics</small></div>
          </div>
          <div class="arch-fabric" aria-hidden="true"><span class="arch-pulse"></span></div>
          <div class="arch-connect" aria-hidden="true"></div>
          <div class="arch-data" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><ellipse cx="8" cy="4" rx="6" ry="2.4" fill="none" stroke="#fff" stroke-width="1.3"/><path d="M2 4v8c0 1.3 2.7 2.4 6 2.4s6-1.1 6-2.4V4" fill="none" stroke="#fff" stroke-width="1.3"/><path d="M2 8c0 1.3 2.7 2.4 6 2.4s6-1.1 6-2.4" fill="none" stroke="#fff" stroke-width="1.3"/></svg>
            One shared data layer
          </div>
        </div>
        <!-- Story points -->
        <div class="arch-points" data-reveal data-delay="1">
          <p class="lead" style="margin-bottom:.5rem;">Most "dental tech stacks" are separate products forced to talk to each other. Tavali is the opposite — a system that doesn't just store your data in one place; it acts on it as one.</p>
          <div class="arch-point">
            <span class="ap-ico" data-dots="0100010101001010010101000" data-size="22"></span>
            <div><h3>One shared data layer</h3><p>Every horizon reads and writes the same record — no syncing, no integrations to break.</p></div>
          </div>
          <div class="arch-point">
            <span class="ap-ico" data-dots="1000101010001000101010001" data-size="22"></span>
            <div><h3>A single agent fabric</h3><p>TAVI, a conversational assistant, orchestrates specialized AI agents across the whole platform.</p></div>
          </div>
          <div class="arch-point">
            <span class="ap-ico" data-dots="0111001010011100101001110" data-size="22"></span>
            <div><h3>Trust-tier governance</h3><p>Clinical decisions always stay with the provider through a non-overridable safeguard.</p></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== SIX HORIZONS — IN DEPTH ===================================================== -->
  <section class="section--tight" style="padding-bottom:0;">
    <div class="container">
      <div class="section-head center" data-reveal>
        <span class="eyebrow">The six horizons</span>
        <h2>Six layers of intelligence — explored.</h2>
        <p class="lead">Each of Tavali's six horizons is a complete layer in its own right — and their power comes from sharing one data layer and one agent fabric.</p>
      </div>
    </div>
  </section>

  <!-- Horizon 1: Clinical AI -->
  <section class="hz-row bg-surface" id="h-clinical-ai" aria-labelledby="hz1-h">
    <div class="container hz-inner">
      <div class="hz-text" data-reveal>
        <span class="hz-eyebrow"><span class="n">01</span> · Clinical AI</span>
        <h2 id="hz1-h">Clinical AI</h2>
        <p class="hz-def"><strong>Clinical AI is Tavali's layer for AI-assisted documentation, diagnostic support, and charting at the point of care.</strong></p>
        <ul class="hz-bullets">
          <li><span class="bdot" aria-hidden="true"></span>Ambient AI scribe that drafts notes from the visit</li>
          <li><span class="bdot" aria-hidden="true"></span>Diagnostic support that surfaces findings for provider review</li>
          <li><span class="bdot" aria-hidden="true"></span>Structured charting that flows into the record</li>
          <li><span class="bdot" aria-hidden="true"></span>Returns clinician time to the chair</li>
        </ul>
        <p class="hz-link"><a class="textlink" href="platform/clinical-ai">Learn more about Clinical AI <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a></p>
      </div>
      <div class="hz-visual" data-reveal data-delay="1">
        <div class="hz-panel">
          <div class="dot-field" aria-hidden="true"></div>
          <div class="hz-panel-head"><span class="hz-panel-ico" data-dots="0010000100112110010000100" data-size="30"></span><span><span class="t" style="display:block;">Ambient scribe</span><span class="s">drafting from the visit</span></span></div>
          <div class="hz-rows" aria-hidden="true">
            <div class="hz-abrow"><span class="lab">Visit transcript</span><span class="chip">live</span></div>
            <div class="hz-abrow"><span class="lab">Drafting note</span><span class="hz-meter"><i style="width:72%"></i></span></div>
            <div class="hz-abrow"><span class="lab">SOAP note → record</span><span class="chip green">ready</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Horizon 2: Front Office -->
  <section class="hz-row hz-row--flip" id="h-front-office" aria-labelledby="hz2-h">
    <div class="container hz-inner">
      <div class="hz-text" data-reveal>
        <span class="hz-eyebrow"><span class="n">02</span> · Front Office</span>
        <h2 id="hz2-h">Front Office</h2>
        <p class="hz-def"><strong>Front Office is Tavali's layer that unifies scheduling, patient communications, and intake on a single screen.</strong></p>
        <ul class="hz-bullets">
          <li><span class="bdot" aria-hidden="true"></span>Unified scheduling and calendar</li>
          <li><span class="bdot" aria-hidden="true"></span>Patient messaging and reminders</li>
          <li><span class="bdot" aria-hidden="true"></span>Digital intake and forms</li>
          <li><span class="bdot" aria-hidden="true"></span>Call and softphone experience in one place</li>
        </ul>
        <p class="hz-link"><a class="textlink" href="platform/front-office">Learn more about Front Office <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a></p>
      </div>
      <div class="hz-visual" data-reveal data-delay="1">
        <div class="hz-panel">
          <div class="dot-field" aria-hidden="true"></div>
          <div class="hz-panel-head"><span class="hz-panel-ico" data-dots="1111110201100011000111111" data-size="30"></span><span><span class="t" style="display:block;">Today's schedule</span><span class="s">one screen, front to back</span></span></div>
          <div class="hz-rows" aria-hidden="true">
            <div class="hz-abrow"><span class="lab">9:00 · Cleaning</span><span class="chip green">confirmed</span></div>
            <div class="hz-abrow"><span class="lab">Recall reminders</span><span class="chip">sent</span></div>
            <div class="hz-abrow"><span class="lab">Digital intake</span><span class="hz-meter"><i style="width:85%"></i></span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Horizon 3: PMS / EHR -->
  <section class="hz-row bg-surface" id="h-pms-ehr" aria-labelledby="hz3-h">
    <div class="container hz-inner">
      <div class="hz-text" data-reveal>
        <span class="hz-eyebrow"><span class="n">03</span> · PMS / EHR</span>
        <h2 id="hz3-h">PMS / EHR</h2>
        <p class="hz-def"><strong>The PMS/EHR layer is Tavali's complete system of record for patients, charts, and billing.</strong></p>
        <ul class="hz-bullets">
          <li><span class="bdot" aria-hidden="true"></span>Patient and family records</li>
          <li><span class="bdot" aria-hidden="true"></span>Clinical charting and history</li>
          <li><span class="bdot" aria-hidden="true"></span>Billing and the financial ledger</li>
          <li><span class="bdot" aria-hidden="true"></span>One source of truth across the practice</li>
        </ul>
        <p class="hz-link"><a class="textlink" href="platform/pms-ehr">Learn more about PMS / EHR <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a></p>
      </div>
      <div class="hz-visual" data-reveal data-delay="1">
        <div class="hz-panel">
          <div class="dot-field" aria-hidden="true"></div>
          <div class="hz-panel-head"><span class="hz-panel-ico" data-dots="1111000000112100000011110" data-size="30"></span><span><span class="t" style="display:block;">Patient record</span><span class="s">#19-MO · one source of truth</span></span></div>
          <div class="hz-rows" aria-hidden="true">
            <div class="hz-abrow"><span class="lab">Chart &amp; history</span><span class="chip">synced</span></div>
            <div class="hz-abrow"><span class="lab">Financial ledger</span><span class="chip green">balanced</span></div>
            <div class="hz-abrow"><span class="lab">Records integrity</span><span class="hz-meter"><i style="width:100%"></i></span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Horizon 4: Intelligence -->
  <section class="hz-row hz-row--flip" id="h-intelligence" aria-labelledby="hz4-h">
    <div class="container hz-inner">
      <div class="hz-text" data-reveal>
        <span class="hz-eyebrow"><span class="n">04</span> · Intelligence</span>
        <h2 id="hz4-h">Intelligence</h2>
        <p class="hz-def"><strong>Intelligence is Tavali's analytics layer for prediction, forecasting, and denial prevention.</strong></p>
        <ul class="hz-bullets">
          <li><span class="bdot" aria-hidden="true"></span>Predictive practice analytics</li>
          <li><span class="bdot" aria-hidden="true"></span>Revenue forecasting</li>
          <li><span class="bdot" aria-hidden="true"></span>Denial-risk scoring before submission</li>
          <li><span class="bdot" aria-hidden="true"></span>Performance insight across locations</li>
        </ul>
        <p class="hz-link"><a class="textlink" href="platform/intelligence">Learn more about Intelligence <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a></p>
      </div>
      <div class="hz-visual" data-reveal data-delay="1">
        <div class="hz-panel">
          <div class="dot-field" aria-hidden="true"></div>
          <div class="hz-panel-head"><span class="hz-panel-ico" data-dots="0000200012001120111211112" data-size="30"></span><span><span class="t" style="display:block;">Forecast</span><span class="s">predict · prevent · plan</span></span></div>
          <div class="hz-rows" aria-hidden="true">
            <div class="hz-abrow"><span class="lab">Denial risk</span><span class="chip green">low</span></div>
            <div class="hz-abrow"><span class="lab">Revenue forecast</span><span class="hz-meter"><i style="width:64%"></i></span></div>
            <div class="hz-abrow"><span class="lab">Across locations</span><span class="chip">+ trending</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Horizon 5: Agents -->
  <section class="hz-row bg-surface" id="h-agents" aria-labelledby="hz5-h">
    <div class="container hz-inner">
      <div class="hz-text" data-reveal>
        <span class="hz-eyebrow"><span class="n">05</span> · Agents</span>
        <h2 id="hz5-h">Agents</h2>
        <p class="hz-def"><strong>Agents are Tavali's autonomous AI workers that carry out multi-step tasks under provider and staff control.</strong></p>
        <ul class="hz-bullets">
          <li><span class="bdot" aria-hidden="true"></span>Scheduling, billing, eligibility, and follow-up agents</li>
          <li><span class="bdot" aria-hidden="true"></span>Orchestrated by the TAVI assistant</li>
          <li><span class="bdot" aria-hidden="true"></span>Act within defined trust-tier limits</li>
          <li><span class="bdot" aria-hidden="true"></span>Do the work, not just record it</li>
        </ul>
        <p class="hz-link"><a class="textlink" href="platform/agents">Learn more about Agents <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a></p>
      </div>
      <div class="hz-visual" data-reveal data-delay="1">
        <div class="hz-panel">
          <div class="dot-field" aria-hidden="true"></div>
          <div class="hz-panel-head"><span class="hz-panel-ico" data-dots="1000100000002000000010001" data-size="30"></span><span><span class="t" style="display:block;">Agents at work</span><span class="s">orchestrated by TAVI</span></span></div>
          <div class="hz-rows" aria-hidden="true">
            <div class="hz-abrow"><span class="lab">Eligibility agent</span><span class="chip green">done</span></div>
            <div class="hz-abrow"><span class="lab">Follow-up agent</span><span class="chip">queued</span></div>
            <div class="hz-abrow"><span class="lab">Billing agent</span><span class="hz-meter"><i style="width:48%"></i></span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Horizon 6: Diagnostics -->
  <section class="hz-row hz-row--flip" id="h-diagnostics" aria-labelledby="hz6-h">
    <div class="container hz-inner">
      <div class="hz-text" data-reveal>
        <span class="hz-eyebrow"><span class="n">06</span> · Diagnostics</span>
        <h2 id="hz6-h">Diagnostics</h2>
        <p class="hz-def"><strong>Diagnostics is Tavali's imaging-intelligence layer across X-ray, CBCT, and intraoral scans, unified per tooth.</strong></p>
        <ul class="hz-bullets">
          <li><span class="bdot" aria-hidden="true"></span>Findings across 2D radiographs, CBCT, and intraoral scans</li>
          <li><span class="bdot" aria-hidden="true"></span>A tooth-level model that unifies findings across modalities</li>
          <li><span class="bdot" aria-hidden="true"></span>Diagnostic support for the provider</li>
          <li><span class="bdot" aria-hidden="true"></span>Imaging that connects to the rest of the record</li>
        </ul>
        <p class="hz-link"><a class="textlink" href="platform/diagnostics">Learn more about Diagnostics <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a></p>
      </div>
      <div class="hz-visual" data-reveal data-delay="1">
        <div class="hz-panel">
          <div class="dot-field" aria-hidden="true"></div>
          <div class="hz-panel-head"><span class="hz-panel-ico" data-dots="0111011111112110101001010" data-size="30"></span><span><span class="t" style="display:block;">Imaging intelligence</span><span class="s">unified per tooth · #19</span></span></div>
          <div class="hz-rows" aria-hidden="true">
            <div class="hz-abrow"><span class="lab">Bitewing &amp; CBCT</span><span class="chip">read</span></div>
            <div class="hz-abrow"><span class="lab">Intraoral scan</span><span class="chip">read</span></div>
            <div class="hz-abrow"><span class="lab">Per-tooth model</span><span class="chip green">unified</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== INTEGRATION MOAT ===================================================== -->
  <section class="section bg-navy moat" id="moat" aria-labelledby="moat-h">
    <div class="dot-field" aria-hidden="true" style="opacity:.1;"></div>
    <div class="moat-aura" aria-hidden="true"></div>
    <div class="container">
      <div class="section-head center" style="max-width:840px;">
        <span class="eyebrow" data-reveal>The integration moat</span>
        <h2 id="moat-h" style="color:#fff;" data-reveal data-delay="1">From a single finding to a paid claim — one intelligent flow.</h2>
