---
/**
 * faq.astro — migrated from "FAQ.html".
 * Static marketing/content page. Shared chrome (head, header, nav, footer) is
 * provided by BaseLayout; this file holds the page-unique <main> body and its
 * structured data. Generated by scripts/migrate-pages.mjs, then maintained by
 * hand.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/styles-faq.css';
---
<BaseLayout
  title="Tavali FAQ — Answers About the AI-Native Dental Platform"
  description="Answers to the most common questions about Tavali — the AI-native operating system for dental practices. Learn what Tavali is, how its AI stays under clinician control, how it reduces denials and saves time, pricing, and security."
  canonical="https://www.tavali.com/resources/faq/"
  ogDescription="The definitive plain-language reference on what Tavali is and does — about the platform, AI safety and control, outcomes, pricing, and security."
  ogImage="https://www.tavali.com/og-faq.png"
  ogImageAlt="Tavali FAQ — answers about the AI-native dental operating system."
  thumbnailLabel="FAQ"
>
  <Fragment slot="jsonld" set:html={`<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": "https://www.tavali.com/resources/faq/#faq",
  "url": "https://www.tavali.com/resources/faq/",
  "inLanguage": "en-US",
  "mainEntity": [
    { "@type": "Question", "name": "What is Tavali?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali is an AI-native operating system for dental practices that unifies clinical intelligence, front-office operations, practice management, billing, and autonomous AI agents in one platform." } },
    { "@type": "Question", "name": "What does \"AI-native\" mean?", "acceptedAnswer": { "@type": "Answer", "text": "AI-native means Tavali was built around AI from the ground up — a conversational assistant and specialized agents that perform work across the practice — rather than adding AI features onto legacy software." } },
    { "@type": "Question", "name": "Who is Tavali for?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali serves single-location offices, group practices, dental service organizations (DSOs), and franchises." } },
    { "@type": "Question", "name": "What is TAVI?", "acceptedAnswer": { "@type": "Answer", "text": "TAVI is Tavali’s conversational assistant that orchestrates specialized AI agents across the platform on the user’s behalf." } },
    { "@type": "Question", "name": "What are Tavali’s six product horizons?", "acceptedAnswer": { "@type": "Answer", "text": "Clinical AI, Front Office, PMS/EHR, Intelligence, Agents, and Diagnostics — six layers that share one data layer and one agent fabric." } },
    { "@type": "Question", "name": "Does Tavali replace my existing practice-management system?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali is a complete platform with its own PMS/EHR layer, designed to be the single system a practice runs on rather than another add-on." } },
    { "@type": "Question", "name": "What makes Tavali different from point solutions?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali connects the entire workflow on one data layer — from a clinical finding through to a payer-ready claim — which separate tools cannot do." } },
    { "@type": "Question", "name": "Can Tavali scale across multiple locations?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Tavali is built for single offices, group practices, DSOs, and franchises, with centralized governance across locations." } },
    { "@type": "Question", "name": "Does Tavali keep clinicians in control?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Clinical decisions are always provider-approved through a trust-tier governance model, and agents act within defined limits." } },
    { "@type": "Question", "name": "Will Tavali’s AI make clinical decisions on its own?", "acceptedAnswer": { "@type": "Answer", "text": "No. Anything clinical is held for provider approval through a non-overridable safeguard; only routine, low-risk tasks can run autonomously." } },
    { "@type": "Question", "name": "How does Tavali avoid AI errors in coding?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali uses grounded, AI-assisted coding that selects accurate codes only from authoritative code sets and routes lower-confidence cases for human review." } },
    { "@type": "Question", "name": "How does Tavali reduce claim denials?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali scores claims for denial risk before submission and uses grounded, AI-assisted coding to bill accurately, reducing denials caused by incorrect coding." } },
    { "@type": "Question", "name": "How does Tavali help with staffing shortages?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali automates administrative work and guides staff through tasks in real time, so a smaller or less-specialized team can run the practice effectively." } },
    { "@type": "Question", "name": "How does Tavali save clinicians time?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali’s ambient AI scribe drafts clinical notes from the visit, reducing documentation and after-hours charting." } },
    { "@type": "Question", "name": "Can I start small and expand later?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Tavali is modular, so a practice can begin with one or two high-impact areas and expand across the platform without switching systems." } },
    { "@type": "Question", "name": "How much does Tavali cost?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali uses subscription pricing billed per location, tailored to your practice’s size, modules, and organization type, and provided through a custom quote — book a demo to get one." } },
    { "@type": "Question", "name": "Is there a demo?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Tavali offers a personalized demo where you can see the platform applied to your practice." } },
    { "@type": "Question", "name": "Is Tavali secure?", "acceptedAnswer": { "@type": "Answer", "text": "Tavali is built with privacy-by-design, encryption, access controls, and audit logging to protect patient data." } },
    { "@type": "Question", "name": "Does Tavali support HIPAA-aligned operations?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Tavali is designed to support HIPAA-aligned workflows, with administrative, technical, and physical safeguards appropriate to protected health information." } }
  ]
}
</script>
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": "https://www.tavali.com/resources/faq/#breadcrumb",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.tavali.com/" },
    { "@type": "ListItem", "position": 2, "name": "Resources", "item": "https://www.tavali.com/resources/" },
    { "@type": "ListItem", "position": 3, "name": "FAQ", "item": "https://www.tavali.com/resources/faq/" }
  ]
}
</script>`} />

<main id="main">

  <!-- ===================================================== HERO ===================================================== -->
  <section class="hero hero--faq" aria-labelledby="page-h">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-bg-dots"></div>
      <div class="hero-glow"></div>
    </div>
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li class="sep" aria-hidden="true">/</li>
          <li><a href="/resources">Resources</a></li>
          <li class="sep" aria-hidden="true">/</li>
          <li><span aria-current="page">FAQ</span></li>
        </ol>
      </nav>
      <div class="hero-grid">
        <div class="hero-copy">
          <span class="eyebrow" data-reveal>Frequently asked questions</span>
          <h1 id="page-h" data-reveal data-delay="1">Tavali, answered.</h1>
          <p class="hero-def" data-reveal data-delay="1">Tavali is an <span class="accent">AI-native operating system</span> for dental practices that unifies clinical care, operations, and revenue into a single, AI-driven platform.</p>
          <p class="hero-sub" data-reveal data-delay="2">Clear, factual answers about what Tavali is, how its AI stays under clinician control, and how it helps your practice — for humans and AI assistants alike.</p>
          <div class="hero-cta" data-reveal data-delay="3">
            <a class="btn btn--primary btn--hero" href="#faq-cta">Book a Demo <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== FAQ ===================================================== -->
  <section class="section" id="faqs" aria-label="Frequently asked questions by category">
    <div class="container faq-layout">
      <nav class="faq-nav" aria-label="FAQ categories">
        <div class="faq-nav-inner">
          <p class="faq-nav-label">Categories</p>
        <a href="#cat-about">About Tavali</a>
        <a href="#cat-platform">The platform</a>
        <a href="#cat-safety">AI, safety &amp; control</a>
        <a href="#cat-outcomes">Outcomes &amp; value</a>
        <a href="#cat-pricing">Pricing</a>
        <a href="/security">Security &amp; data</a>
        </div>
      </nav>
      <div class="faq-cats">
      <section class="faq-cat" id="cat-about" aria-labelledby="cat-about-h" data-reveal>
        <div class="faq-cat-head">
          <span class="faq-cat-ico" data-dots="0010000100112110010000100" data-size="38"></span>
          <h2 id="cat-about-h">About Tavali</h2>
        </div>
        <div class="faq-wrap">
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>What is Tavali?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Tavali is an AI-native operating system for dental practices that unifies clinical intelligence, front-office operations, practice management, billing, and autonomous AI agents in one platform.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>What does &quot;AI-native&quot; mean?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>AI-native means Tavali was built around AI from the ground up — a conversational assistant and specialized agents that perform work across the practice — rather than adding AI features onto legacy software.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>Who is Tavali for?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Tavali serves single-location offices, group practices, dental service organizations (DSOs), and franchises.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>What is TAVI?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>TAVI is Tavali&rsquo;s conversational assistant that orchestrates specialized AI agents across the platform on the user&rsquo;s behalf.</p></div></div>
        </div>
        </div>
      </section>

      <section class="faq-cat" id="cat-platform" aria-labelledby="cat-platform-h" data-reveal>
        <div class="faq-cat-head">
          <span class="faq-cat-ico" data-dots="1111110201100011000111111" data-size="38"></span>
          <h2 id="cat-platform-h">The platform</h2>
        </div>
        <div class="faq-wrap">
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>What are Tavali&rsquo;s six product horizons?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Clinical AI, Front Office, PMS/EHR, Intelligence, Agents, and Diagnostics — six layers that share one data layer and one agent fabric.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>Does Tavali replace my existing practice-management system?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Tavali is a complete platform with its own PMS/EHR layer, designed to be the single system a practice runs on rather than another add-on.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>What makes Tavali different from point solutions?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Tavali connects the entire workflow on one data layer — from a clinical finding through to a payer-ready claim — which separate tools cannot do.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>Can Tavali scale across multiple locations?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Yes. Tavali is built for single offices, group practices, DSOs, and franchises, with centralized governance across locations.</p></div></div>
        </div>
        </div>
      </section>

      <section class="faq-cat" id="cat-safety" aria-labelledby="cat-safety-h" data-reveal>
        <div class="faq-cat-head">
          <span class="faq-cat-ico" data-dots="0010001110111110111000100" data-size="38"></span>
          <h2 id="cat-safety-h">AI, safety &amp; control</h2>
        </div>
        <div class="faq-wrap">
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>Does Tavali keep clinicians in control?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Yes. Clinical decisions are always provider-approved through a trust-tier governance model, and agents act within defined limits.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>Will Tavali&rsquo;s AI make clinical decisions on its own?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>No. Anything clinical is held for provider approval through a non-overridable safeguard; only routine, low-risk tasks can run autonomously.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>How does Tavali avoid AI errors in coding?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Tavali uses grounded, AI-assisted coding that selects accurate codes only from authoritative code sets and routes lower-confidence cases for human review.</p></div></div>
        </div>
        </div>
      </section>

      <section class="faq-cat" id="cat-outcomes" aria-labelledby="cat-outcomes-h" data-reveal>
        <div class="faq-cat-head">
          <span class="faq-cat-ico" data-dots="0000200012001120111211112" data-size="38"></span>
          <h2 id="cat-outcomes-h">Outcomes &amp; value</h2>
        </div>
        <div class="faq-wrap">
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>How does Tavali reduce claim denials?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Tavali scores claims for denial risk before submission and uses grounded, AI-assisted coding to bill accurately, reducing denials caused by incorrect coding.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>How does Tavali help with staffing shortages?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Tavali automates administrative work and guides staff through tasks in real time, so a smaller or less-specialized team can run the practice effectively.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>How does Tavali save clinicians time?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Tavali&rsquo;s ambient AI scribe drafts clinical notes from the visit, reducing documentation and after-hours charting.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>Can I start small and expand later?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Yes. Tavali is modular, so a practice can begin with one or two high-impact areas and expand across the platform without switching systems.</p></div></div>
        </div>
        </div>
      </section>

      <section class="faq-cat" id="cat-pricing" aria-labelledby="cat-pricing-h" data-reveal>
        <div class="faq-cat-head">
          <span class="faq-cat-ico" data-dots="0111010001100011000101110" data-size="38"></span>
          <h2 id="cat-pricing-h">Pricing</h2>
        </div>
        <div class="faq-wrap">
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>How much does Tavali cost?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Tavali uses subscription pricing billed per location, tailored to your practice&rsquo;s size, modules, and organization type, and provided through a custom quote — book a demo to get one.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>Is there a demo?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Yes. Tavali offers a personalized demo where you can see the platform applied to your practice.</p></div></div>
        </div>
        </div>
      </section>

      <section class="faq-cat" id="cat-security" aria-labelledby="cat-security-h" data-reveal>
        <div class="faq-cat-head">
          <span class="faq-cat-ico" data-dots="0010001010101010101000100" data-size="38"></span>
          <h2 id="cat-security-h">Security &amp; data</h2>
        </div>
        <div class="faq-wrap">
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>Is Tavali secure?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Tavali is built with privacy-by-design, encryption, access controls, and audit logging to protect patient data.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false"><h3>Does Tavali support HIPAA-aligned operations?</h3><span class="faq-icon" aria-hidden="true"></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>Yes. Tavali is designed to support HIPAA-aligned workflows, with administrative, technical, and physical safeguards appropriate to protected health information.</p></div></div>
        </div>
        </div>
      </section>
      </div>
    </div>
  </section>

  <!-- ===================================================== STILL HAVE QUESTIONS ===================================================== -->
  <section class="section--tight bg-surface" aria-labelledby="still-h">
    <div class="container">
      <div class="news-band" data-reveal>
        <div class="news-band-text">
          <h3 id="still-h">Didn&rsquo;t find your answer?</h3>
          <p>Talk to our team — we&rsquo;ll answer your questions and show you Tavali on your own workflows.</p>
        </div>
        <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
          <a class="btn btn--primary" href="#faq-cta">Book a Demo</a>
          <a class="btn btn--ghost" href="#faq-cta">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================================================== FINAL CTA ===================================================== -->
  <section class="section bg-navy final-cta" id="faq-cta" aria-labelledby="final-h">
    <div class="hero-glow" aria-hidden="true" style="left:50%;top:-30%;transform:translateX(-50%);"></div>
    <div class="dot-field" aria-hidden="true" style="opacity:.1;-webkit-mask-image:radial-gradient(ellipse 70% 100% at 50% 0,#000,transparent 70%);mask-image:radial-gradient(ellipse 70% 100% at 50% 0,#000,transparent 70%);"></div>
    <div class="container final-cta-inner">
      <h2 id="final-h" data-reveal>Still have questions?</h2>
      <p class="lead" data-reveal data-delay="1">Book a 30-minute demo and we&rsquo;ll walk your team through Tavali — and answer whatever the FAQ didn&rsquo;t.</p>
      <div class="final-cta-row" data-reveal data-delay="2">
        <a class="btn btn--primary btn--lg" href="#">Book a Demo <svg class="btn-arrow" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8 4m4 4l-4 4" stroke="currentColor" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        <a class="btn btn--ghost btn--lg" href="/platform">Explore the Platform</a>
      </div>
    </div>
  </section>

</main>
</BaseLayout>
