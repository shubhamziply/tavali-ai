---
/**
 * Head.astro — document <head>: charset/viewport, SEO meta, Open Graph,
 * Twitter Card, theme-color, and canonical URL. Mirrors the per-page <head>
 * blocks from the original site. JSON-LD structured data is passed through the
 * default <slot/> so each page keeps its own schema.org markup.
 */
interface Props {
  title: string;
  description: string;
  /** Canonical path (e.g. "/blog/") or absolute URL. Resolved against site. */
  canonical?: string;
  ogType?: 'website' | 'article';
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogImageAlt?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  twitterImage?: string;
  /** Optional article metadata (only emitted for ogType="article"). */
  publishedTime?: string;
  modifiedTime?: string;
  section?: string;
}

const site = Astro.site ?? new URL('https://www.tavali.com');
const {
  title,
  description,
  canonical = Astro.url.pathname,
  ogType = 'website',
  ogTitle = title,
  ogDescription = description,
  ogImage = new URL('/og-image.png', site).href,
  ogImageAlt = 'Tavali — the AI-native operating system for dental practices.',
  twitterTitle = title,
  twitterDescription = description,
  twitterImage = ogImage,
  publishedTime,
  modifiedTime,
  section,
} = Astro.props;

// Build an absolute canonical URL from a path when needed.
const canonicalUrl = canonical.startsWith('http')
  ? canonical
  : new URL(canonical, site).href;
---
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>{title}</title>
<meta name="description" content={description} />
<meta name="theme-color" content="#0F2A4A" />

<!-- Mark JS-ready ASAP so reveal-on-scroll only hides content when scripting can restore it -->
<script is:inline>document.documentElement.classList.add('js');</script>

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content="Tavali" />
<meta property="og:title" content={ogTitle} />
<meta property="og:description" content={ogDescription} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={ogImageAlt} />
{ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
{ogType === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{ogType === 'article' && section && <meta property="article:section" content={section} />}
{ogType === 'article' && <meta property="article:publisher" content="Tavali, Inc." />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={twitterTitle} />
<meta name="twitter:description" content={twitterDescription} />
<meta name="twitter:image" content={twitterImage} />

<link rel="canonical" href={canonicalUrl} />

<!-- Page-specific structured data (JSON-LD) -->
<slot />
